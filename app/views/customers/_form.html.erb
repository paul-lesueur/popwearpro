<% submit_text = local_assigns[:submit_label] || "Enregistrer le client" %>

<div class="customer-form-layout">
  <div class="customer-form-card">
    <div class="customer-form-card-header">
      <div class="customer-form-icon">
        <i class="fa fa-user"></i>
      </div>

      <div>
        <h2>Informations client</h2>
        <p>Renseignez les informations principales du client.</p>
      </div>
    </div>

    <%= form_with(model: customer, local: true, class: "customer-form") do |f| %>
      <% if customer.errors.any? %>
        <div class="customer-form-errors">
          <h3>Impossible d’enregistrer ce client</h3>

          <ul>
            <% customer.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="customer-form-grid">
        <div class="customer-form-field">
          <%= f.label :firstname, "Prénom" %>
          <%= f.text_field :firstname, placeholder: "Ex : Camille", class: "customer-input" %>
        </div>

        <div class="customer-form-field">
          <%= f.label :lastname, "Nom" %>
          <%= f.text_field :lastname, placeholder: "Ex : Mercier", class: "customer-input" %>
        </div>
      </div>

      <div class="customer-form-field">
        <%= f.label :email, "Adresse e-mail" %>

        <div class="customer-input-with-icon">
          <i class="fa fa-envelope"></i>
          <%= f.email_field :email, placeholder: "Ex : camille@email.fr", class: "customer-input" %>
        </div>
      </div>

      <div class="customer-form-field">
        <%= f.label :phone, "Téléphone" %>

        <div class="customer-input-with-icon">
          <i class="fa fa-phone"></i>
          <%= f.telephone_field :phone, placeholder: "Ex : 06 12 34 56 78", class: "customer-input" %>
        </div>
      </div>

      <div class="customer-form-field">
        <%= f.label :notes, "Notes internes" %>
        <%= f.text_area :notes,
          rows: 5,
          placeholder: "Ex : Cliente fidèle, préfère être prévenue par SMS.",
          class: "customer-input customer-textarea" %>
      </div>

      <div class="customer-form-actions">
        <%= link_to "Annuler", customers_path, class: "btn btn-outline-primary" %>
        <%= f.submit submit_text, class: "customer-btn-primary" %>
      </div>
    <% end %>
  </div>

  <aside class="customer-form-side-card">
    <div class="customer-form-side-icon">
      <i class="fa fa-address-book"></i>
    </div>

    <h3>Carnet client établissement</h3>

    <p>
      Chaque client ajouté pourra ensuite être relié à ses commandes, ses paiements et son historique dans Popwear Pro.
    </p>

    <div class="customer-form-tips">
      <div>
        <i class="fa fa-check"></i>
        <span>Coordonnées centralisées</span>
      </div>

      <div>
        <i class="fa fa-check"></i>
        <span>Notes internes visibles par l’établissement</span>
      </div>

      <div>
        <i class="fa fa-check"></i>
        <span>Historique de commandes accessible depuis la fiche client</span>
      </div>
    </div>
  </aside>
</div>
