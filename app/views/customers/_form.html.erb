<%= form_with model: customer, local: true do |form| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger">
      <p><strong>Erreur :</strong></p>
      <ul>
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :firstname, "Prénom", class: "form-label" %>
    <%= form.text_field :firstname, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :lastname, "Nom", class: "form-label" %>
    <%= form.text_field :lastname, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :email, "Email", class: "form-label" %>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :phone, "Téléphone", class: "form-label" %>
    <%= form.text_field :phone, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :notes, "Notes", class: "form-label" %>
    <%= form.text_area :notes, rows: 4, class: "form-control" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit "Enregistrer", class: "btn btn-primary" %>
    <%= link_to "Annuler", customers_path, class: "btn btn-secondary" %>
  </div>
<% end %>
