<%
  current_sort = params[:sort].presence
  current_direction = params[:direction] == "asc" ? "asc" : "desc"

  next_direction_for = lambda do |column|
    current_sort == column && current_direction == "asc" ? "desc" : "asc"
  end

  sort_icon_for = lambda do |column|
    if current_sort == column
      current_direction == "asc" ? "↑" : "↓"
    else
      ""
    end
  end

  order_status_labels = {
    "new" => "Nouvelle",
    "pending" => "En attente",
    "in_progress" => "En cours",
    "recollect" => "À récupérer",
    "done" => "Terminée",
    "completed" => "Terminée",
    "delivered" => "Livrée",
    "sent" => "Envoyée",
    "cancelled" => "Annulée"
  }

  payment_status_labels = {
    "paid" => "Payé",
    "unpaid" => "En attente de paiement",
    "pending" => "En attente",
    "partial" => "Partiel",
    "refunded" => "Remboursé",
    "cancelled" => "Annulé"
  }

  priority_labels = {
    "low" => "Faible",
    "normal" => "Normale",
    "medium" => "Moyenne",
    "high" => "Haute",
    "urgent" => "Urgent"
  }
%>

<div class="customers-page" data-controller="customer-panel">
  <section class="customers-main">
    <div class="customers-header">
      <div>
        <h1>Clients</h1>
        <p>Retrouvez les clients de votre établissement, leurs coordonnées et leur historique de commandes.</p>
      </div>

      <%= link_to "Créer un client", new_customer_path, class: "btn btn-primary" %>
    </div>

    <div class="customers-stats">
      <div class="customer-stat-card customer-stat-card--orange">
        <div class="customer-stat-icon customer-stat-icon--orange">
          <i class="fa-solid fa-users"></i>
        </div>

        <span class="customer-stat-label">Clients</span>
        <strong><%= @customers_count %></strong>
      </div>

      <div class="customer-stat-card customer-stat-card--green">
        <div class="customer-stat-icon customer-stat-icon--green">
          <i class="fa-solid fa-user-plus"></i>
        </div>

        <span class="customer-stat-label">Nouveaux ce mois</span>
        <strong><%= @new_customers_this_month %></strong>
      </div>
    </div>

    <div data-controller="search">
      <%= form_with url: customers_path, method: :get, data: { search_target: "form" }, class: "mb-4" do |f| %>
        <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
        <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>

        <div class="input-group" style="max-width: 380px;">
          <span class="input-group-text bg-white border-end-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
            </svg>
          </span>

          <%= f.text_field :query,
            value: params[:query],
            placeholder: "Rechercher un client ou N° de téléphone…",
            class: "form-control border-start-0 ps-0",
            autocomplete: "off",
            data: { action: "input->search#submit" } %>
        </div>
      <% end %>
    </div>

    <div class="customers-list-card">
      <div class="customers-list-header">
        <span>
          <%= link_to customers_path(request.query_parameters.merge(sort: "lastname", direction: next_direction_for.call("lastname"))), class: "text-reset text-decoration-none" do %>
            Client <%= sort_icon_for.call("lastname") %>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.merge(sort: "email", direction: next_direction_for.call("email"))), class: "text-reset text-decoration-none" do %>
            Contact <%= sort_icon_for.call("email") %>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.merge(sort: "orders_count", direction: next_direction_for.call("orders_count"))), class: "text-reset text-decoration-none" do %>
            Commandes <%= sort_icon_for.call("orders_count") %>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.merge(sort: "created_at", direction: next_direction_for.call("created_at"))), class: "text-reset text-decoration-none" do %>
            Depuis <%= sort_icon_for.call("created_at") %>
          <% end %>
        </span>
      </div>

      <% if @customers.any? %>
        <% @customers.each do |customer| %>
          <% last_order = customer.orders.max_by(&:created_at) %>

          <button
            type="button"
            class="customers-row"
            data-action="click->customer-panel#open"
            data-customer-panel-target="row"
            data-customer-id="<%= customer.id %>"
            data-name="<%= customer.display_name %>"
            data-initials="<%= customer.initials %>"
            data-email="<%= customer.email.presence || 'Email non renseigné' %>"
            data-phone="<%= customer.phone.presence || 'Téléphone non renseigné' %>"
            data-notes="<%= customer.notes.presence || 'Aucune note interne.' %>"
            data-orders-count="<%= customer.orders.size %>"
            data-created-at="<%= customer.created_at.strftime('%d/%m/%Y') %>"
            data-last-order-date="<%= last_order ? last_order.created_at.strftime('%d/%m/%Y') : 'Aucune commande' %>"
            data-edit-url="<%= edit_customer_path(customer) %>"
          >
            <div class="customer-cell-main">
              <div class="customer-avatar">
                <%= customer.initials %>
              </div>

              <div>
                <strong><%= customer.display_name %></strong>
                <span>Client #<%= customer.id %></span>
              </div>
            </div>

            <div class="customer-cell-contact">
              <span><%= customer.email.presence || "Email non renseigné" %></span>
              <small><%= customer.phone.presence || "Téléphone non renseigné" %></small>
            </div>

            <div>
              <span class="customer-orders-count">
                <%= customer.orders.size %>
              </span>
            </div>

            <div>
              <%= customer.created_at.strftime("%d/%m/%Y") %>
            </div>
          </button>

          <template
            data-customer-panel-target="ordersTemplate"
            data-customer-id="<%= customer.id %>"
          >
            <% if customer.orders.any? %>
              <% customer.orders.order(created_at: :desc).limit(5).each do |order| %>
                <div class="customer-panel-order">
                  <div>
                    <strong>Commande #<%= order.id %></strong>
                    <span><%= order.created_at.strftime("%d/%m/%Y") %></span>
                  </div>

                  <div class="customer-panel-order-badges">
                    <% if order.respond_to?(:status) && order.status.present? %>
                      <span class="customer-badge">
                        <%= order_status_labels[order.status.to_s] || order.status.to_s.humanize %>
                      </span>
                    <% end %>

                    <% if order.respond_to?(:payment_status) && order.payment_status.present? %>
                      <span class="customer-badge customer-badge-payment">
                        <%= payment_status_labels[order.payment_status.to_s] || order.payment_status.to_s.humanize %>
                      </span>
                    <% end %>

                    <% if order.respond_to?(:priority) && order.priority.present? %>
                      <span class="customer-badge customer-badge-priority">
                        <%= priority_labels[order.priority.to_s] || order.priority.to_s.humanize %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="customer-panel-empty">Aucune commande pour ce client.</p>
            <% end %>
          </template>
        <% end %>
      <% else %>
        <div class="customers-empty-state">
          <h3>Aucun client pour le moment</h3>
          <p>Ajoutez votre premier client pour commencer à organiser votre établissement.</p>
          <%= link_to "Créer un client", new_customer_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </section>

  <aside class="customer-panel" data-customer-panel-target="panel" aria-hidden="true">
    <div class="customer-panel-header">
      <h2>Fiche client</h2>

      <button type="button" class="customer-panel-close" data-action="click->customer-panel#close">
        Fermer
      </button>
    </div>

    <div class="customer-panel-identity">
      <div class="customer-avatar customer-avatar-large" data-customer-panel-target="initials">
        CL
      </div>

      <div class="customer-panel-name">
        <h3 data-customer-panel-target="name">Client</h3>
        <p data-customer-panel-target="email">Email non renseigné</p>
      </div>

      <a href="#" class="customer-panel-edit" data-customer-panel-target="editLink">
        Modifier
      </a>
    </div>

    <div class="customer-panel-summary">
      <strong data-customer-panel-target="ordersCount">0</strong>
      <span>commande(s)</span>
    </div>

    <div class="customer-panel-card">
      <h4>Coordonnées</h4>

      <div class="customer-contact-line">
        <div class="customer-contact-icon">
          <i class="fa-solid fa-phone"></i>
        </div>

        <div>
          <span>Téléphone</span>
          <strong data-customer-panel-target="phone">Téléphone non renseigné</strong>
        </div>
      </div>

      <div class="customer-contact-line">
        <div class="customer-contact-icon">
          <i class="fa-solid fa-envelope"></i>
        </div>

        <div>
          <span>Adresse e-mail</span>
          <strong data-customer-panel-target="emailInDetails">Email non renseigné</strong>
        </div>
      </div>
    </div>

    <div class="customer-panel-card">
      <h4>Notes internes</h4>
      <p data-customer-panel-target="notes">Aucune note interne.</p>
    </div>

    <div class="customer-panel-card">
      <h4>Historique de commandes</h4>

      <div data-customer-panel-target="orders">
        <p class="customer-panel-empty">Sélectionnez un client pour voir ses commandes.</p>
      </div>
    </div>

    <div class="customer-panel-card">
      <h4>Chronologie</h4>

      <div class="customer-timeline">
        <div class="customer-timeline-item">
          <span class="customer-timeline-dot"></span>

          <div>
            <strong>Dernière commande</strong>
            <p data-customer-panel-target="lastOrderDate">Aucune commande</p>
          </div>
        </div>

        <div class="customer-timeline-item">
          <span class="customer-timeline-dot"></span>

          <div>
            <strong>Création du client</strong>
            <p data-customer-panel-target="createdAt">—</p>
          </div>
        </div>
      </div>
    </div>
  </aside>
</div>
