<%
  current_sort = params[:sort].presence || "created_at"
  current_direction = params[:direction] == "asc" ? "asc" : "desc"

  next_direction_for = lambda do |column|
    current_sort == column && current_direction == "asc" ? "desc" : "asc"
  end

  sort_icon_for = lambda do |column|
    if current_sort == column
      current_direction == "asc" ? "↑" : "↓"
    else
      "↕"
    end
  end

  sort_class_for = lambda do |column|
    current_sort == column ? "customers-sort-link is-active" : "customers-sort-link"
  end

  order_status_labels = {
    "new" => "Nouvelle commande",
    "pending" => "En attente",
    "in_progress" => "En cours",
    "recollect" => "En attente de re-collecte",
    "done" => "Terminée",
    "completed" => "Terminée",
    "delivered" => "Livrée",
    "sent" => "Envoyée",
    "cancelled" => "Annulée"
  }

  payment_status_labels = {
    "paid" => "Paiement Carte",
    "unpaid" => "Non payé",
    "pending" => "Paiement en attente",
    "partial" => "Paiement partiel",
    "refunded" => "Remboursé",
    "cancelled" => "Paiement annulé"
  }
%>

<div class="customers-page" data-controller="customer-panel">
  <section class="customers-main">
    <div class="customers-header">
      <div>
        <h1>Clients</h1>
        <p class="text-muted">Retrouvez les clients de votre atelier, leurs coordonnées et leur historique de commandes.</p>
      </div>

      <%= link_to new_customer_path, class: "btn-cta" do %>
        <i class="fa-solid fa-plus"></i>
        <span>Nouveau client</span>
      <% end %>
    </div>

    <div class="customers-stats">
      <div class="customer-stat-card customer-stat-card--orange">
        <div class="customer-stat-icon customer-stat-icon--orange">
          <i class="fa-solid fa-users"></i>
        </div>

        <span class="customer-stat-label">Clients</span>
        <strong><%= @customers_count %></strong>
      </div>

      <div class="customer-stat-card customer-stat-card--green">
        <div class="customer-stat-icon customer-stat-icon--green">
          <i class="fa-solid fa-user-plus"></i>
        </div>

        <span class="customer-stat-label">Nouveaux ce mois</span>
        <strong><%= @new_customers_this_month %></strong>
      </div>
    </div>

    <div data-controller="search">
      <%= form_with url: customers_path, method: :get, data: { search_target: "form" }, class: "mb-4" do |f| %>
        <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
        <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>

        <div class="input-group" style="max-width: 380px;">
          <span class="input-group-text bg-white border-end-0">
            <i class="fa-solid fa-magnifying-glass text-muted" style="font-size: 0.875rem;"></i>
          </span>

          <%= f.text_field :query,
            value: params[:query],
            placeholder: "Rechercher un client ou téléphone…",
            class: "form-control bg-white border-start-0 ps-0",
            autocomplete: "off",
            data: { action: "input->search#submit" } %>
        </div>
      <% end %>
    </div>

    <div class="customers-list-card">
      <div class="customers-list-header">
        <span>
          <%= link_to customers_path(request.query_parameters.except(:page).merge(sort: "lastname", direction: next_direction_for.call("lastname"))), class: sort_class_for.call("lastname") do %>
            Client <span class="customers-sort-icon"><%= sort_icon_for.call("lastname") %></span>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.except(:page).merge(sort: "email", direction: next_direction_for.call("email"))), class: sort_class_for.call("email") do %>
            Contact <span class="customers-sort-icon"><%= sort_icon_for.call("email") %></span>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.except(:page).merge(sort: "orders_count", direction: next_direction_for.call("orders_count"))), class: sort_class_for.call("orders_count") do %>
            Commandes <span class="customers-sort-icon"><%= sort_icon_for.call("orders_count") %></span>
          <% end %>
        </span>

        <span>
          <%= link_to customers_path(request.query_parameters.except(:page).merge(sort: "created_at", direction: next_direction_for.call("created_at"))), class: sort_class_for.call("created_at") do %>
            Depuis <span class="customers-sort-icon"><%= sort_icon_for.call("created_at") %></span>
          <% end %>
        </span>
      </div>

      <% if @customers.any? %>
        <% @customers.each do |customer| %>
          <% last_order = customer.orders.max_by(&:created_at) %>

          <button
            type="button"
            class="customers-row"
            data-action="click->customer-panel#open"
            data-customer-panel-target="row"
            data-customer-id="<%= customer.id %>"
            data-name="<%= customer.display_name %>"
            data-initials="<%= customer.initials %>"
            data-email="<%= customer.email.presence || 'Email non renseigné' %>"
            data-phone="<%= customer.phone.presence || 'Téléphone non renseigné' %>"
            data-notes="<%= customer.notes.presence || 'Aucune note interne.' %>"
            data-orders-count="<%= customer.orders.size %>"
            data-created-at="<%= customer.created_at.strftime('%d/%m/%Y') %>"
            data-last-order-date="<%= last_order ? last_order.created_at.strftime('%d/%m/%Y') : 'Aucune commande' %>"
            data-edit-url="<%= edit_customer_path(customer) %>"
          >
            <div class="customer-cell-main">
              <div class="customer-avatar">
                <%= customer.initials %>
              </div>

              <div>
                <strong><%= customer.display_name %></strong>
                <span>Client #<%= customer.id %></span>
              </div>
            </div>

            <div class="customer-cell-contact">
              <span><%= customer.email.presence || "Email non renseigné" %></span>
              <small><%= customer.phone.presence || "Téléphone non renseigné" %></small>
            </div>

            <div>
              <span class="customer-orders-count">
                <%= customer.orders.size %>
              </span>
            </div>

            <div>
              <%= customer.created_at.strftime("%d/%m/%Y") %>
            </div>
          </button>

          <template
            data-customer-panel-target="ordersTemplate"
            data-customer-id="<%= customer.id %>"
          >
            <% if customer.orders.any? %>
              <% customer.orders.sort_by(&:created_at).reverse.first(5).each do |order| %>
                <div class="customer-panel-order">
                  <div>
                    <strong>Commande #<%= order.id %></strong>
                    <span><%= order.created_at.strftime("%d/%m/%Y") %></span>
                  </div>

                  <div class="customer-panel-order-badges">
                    <% if order.respond_to?(:status) && order.status.present? %>
                      <span class="<%= customer_order_status_class(order.status) %>">
                        <i class="fa-regular fa-clock"></i>
                        <%= order_status_labels[order.status.to_s] || order.status.to_s.humanize %>
                      </span>
                    <% end %>

                    <% if order.respond_to?(:payment_status) && order.payment_status.present? %>
                      <span class="<%= customer_payment_status_class(order.payment_status) %>">
                        <i class="fa-regular fa-credit-card"></i>
                        <%= payment_status_labels[order.payment_status.to_s] || order.payment_status.to_s.humanize %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="customer-panel-empty">Aucune commande pour ce client.</p>
            <% end %>
          </template>
        <% end %>
      <% else %>
        <div class="customers-empty-state">
          <h3>Aucun client pour le moment</h3>
          <p>Ajoutez votre premier client pour commencer à organiser votre atelier.</p>
          <%= link_to new_customer_path, class: "btn-cta" do %>
            <i class="fa-solid fa-plus"></i>
            <span>Nouveau client</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @total_pages > 1 %>
      <div class="customers-pagination">
        <% if @page > 1 %>
          <%= link_to "‹", customers_path(request.query_parameters.merge(page: @page - 1)) %>
        <% else %>
          <span class="disabled">‹</span>
        <% end %>

        <% (1..@total_pages).each do |page_number| %>
          <% if page_number == @page %>
            <span class="current"><%= page_number %></span>
          <% else %>
            <%= link_to page_number, customers_path(request.query_parameters.merge(page: page_number)) %>
          <% end %>
        <% end %>

        <% if @page < @total_pages %>
          <%= link_to "›", customers_path(request.query_parameters.merge(page: @page + 1)) %>
        <% else %>
          <span class="disabled">›</span>
        <% end %>
      </div>
    <% end %>
  </section>

  <aside class="customer-panel" data-customer-panel-target="panel" aria-hidden="true">
    <div class="customer-panel-body">
      <div class="customer-panel-top">
        <div>
          <h2 data-customer-panel-target="name">Client</h2>
          <p data-customer-panel-target="email">Email non renseigné</p>
        </div>

        <div class="customer-panel-actions">
          <button type="button" class="customer-panel-close" data-action="click->customer-panel#close">
            Fermer
          </button>

          <a href="#" class="customer-panel-edit" data-customer-panel-target="editLink">
            Modifier
          </a>
        </div>
      </div>

      <span class="d-none" data-customer-panel-target="initials">CL</span>

      <div class="customer-panel-section">
        <h4>Résumé client</h4>

        <div class="customer-panel-summary">
          <strong data-customer-panel-target="ordersCount">0</strong>
          <span>commande(s)</span>
        </div>
      </div>

      <div class="customer-panel-section">
        <h4>Coordonnées</h4>

        <div class="customer-contact-line">
          <div class="customer-contact-icon">
            <i class="fa-solid fa-phone"></i>
          </div>

          <div>
            <span>Téléphone</span>
            <strong data-customer-panel-target="phone">Téléphone non renseigné</strong>
          </div>
        </div>

        <div class="customer-contact-line">
          <div class="customer-contact-icon">
            <i class="fa-solid fa-envelope"></i>
          </div>

          <div>
            <span>Adresse e-mail</span>
            <strong data-customer-panel-target="emailInDetails">Email non renseigné</strong>
          </div>
        </div>
      </div>

      <div class="customer-panel-section">
        <h4>Notes internes</h4>
        <p data-customer-panel-target="notes">Aucune note interne.</p>
      </div>

      <div class="customer-panel-section">
        <h4>Historique de commandes</h4>

        <div data-customer-panel-target="orders">
          <p class="customer-panel-empty">Sélectionnez un client pour voir ses commandes.</p>
        </div>
      </div>

      <div class="customer-panel-section">
        <h4>Chronologie</h4>

        <div class="customer-timeline">
          <div class="customer-timeline-item">
            <div class="customer-timeline-icon">
              <i class="fa-solid fa-shirt"></i>
            </div>

            <div>
              <strong class="customer-timeline-label">Dernière commande</strong>
              <p class="customer-timeline-date" data-customer-panel-target="lastOrderDate">Aucune commande</p>
            </div>
          </div>

          <div class="customer-timeline-item">
            <div class="customer-timeline-icon">
              <i class="fa-solid fa-user-plus"></i>
            </div>

            <div>
              <strong class="customer-timeline-label">Création du client</strong>
              <p class="customer-timeline-date" data-customer-panel-target="createdAt">—</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </aside>
</div>
