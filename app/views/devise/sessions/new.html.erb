<div class="auth-page">
  <section class="auth-hero">
    <%= link_to root_path, class: "auth-logo-chip" do %>
      <%= image_tag "logo-popwear-pro.png", alt: "Popwear Pro", class: "auth-logo" %>
    <% end %>

    <div class="auth-hero-content">
      <h1>Pilotez votre atelier simplement.</h1>

      <p>
        Commandes, clients, prestations et ventes réunis dans une interface claire pensée pour les artisans.
      </p>

      <div class="auth-highlights">
        <div>
          <i class="fa-solid fa-check"></i>
          <span>Suivi des commandes atelier</span>
        </div>

        <div>
          <i class="fa-solid fa-check"></i>
          <span>Clients et historique centralisés</span>
        </div>

        <div>
          <i class="fa-solid fa-check"></i>
          <span>Tableau de bord clair et rapide</span>
        </div>
      </div>
    </div>
  </section>

  <section class="auth-form-section">
    <div class="auth-card">
      <div class="auth-card-header">
        <span class="auth-card-kicker">Connexion</span>
        <h2>Se connecter</h2>
        <p>Accédez à votre espace Popwear Pro.</p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    label: "Adresse e-mail",
                    placeholder: "exemple@email.com",
                    input_html: { autocomplete: "email" } %>

        <%= f.input :password,
                    required: false,
                    label: "Mot de passe",
                    placeholder: "Votre mot de passe",
                    input_html: { autocomplete: "current-password" } %>

        <div class="auth-options">
          <% if devise_mapping.rememberable? %>
            <%= f.input :remember_me,
                        as: :boolean,
                        label: "Se souvenir de moi",
                        wrapper_html: { class: "auth-remember" } %>
          <% end %>
        </div>

        <%= f.button :submit, "Se connecter", class: "auth-submit" %>
      <% end %>

      <div class="auth-footer">
        <% if devise_mapping.recoverable? %>
          <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "auth-link auth-password-link" %>
        <% end %>

        <p>
          Pas encore de compte ?
          <%= link_to "Créer un compte", new_registration_path(resource_name), class: "auth-link" %>
        </p>
      </div>
    </div>
  </section>
</div>
