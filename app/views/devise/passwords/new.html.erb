<div class="auth-page">
  <section class="auth-hero">
    <%= link_to root_path, class: "auth-logo-chip" do %>
      <%= image_tag "logo-popwear-pro.png", alt: "Popwear Pro", class: "auth-logo" %>
    <% end %>

    <div class="auth-hero-content">
      <h1>Récupérez votre accès.</h1>

      <p>
        Recevez un lien sécurisé pour réinitialiser votre mot de passe et retrouver votre espace.
      </p>

      <div class="auth-highlights">
        <div>
          <i class="fa-solid fa-check"></i>
          <span>Réinitialisation sécurisée</span>
        </div>

        <div>
          <i class="fa-solid fa-check"></i>
          <span>Retour rapide à votre espace</span>
        </div>

        <div>
          <i class="fa-solid fa-check"></i>
          <span>Données atelier protégées</span>
        </div>
      </div>
    </div>
  </section>

  <section class="auth-form-section">
    <div class="auth-card auth-card--password">
      <div class="auth-card-header">
        <span class="auth-card-kicker">Mot de passe oublié</span>
        <h2>Réinitialiser votre accès</h2>
        <p>Entrez l’adresse e-mail associée à votre compte.</p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
        <%= f.error_notification %>

        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Adresse e-mail",
                    placeholder: "exemple@email.com",
                    input_html: { autocomplete: "email" } %>

        <%= f.button :submit, "Recevoir le lien", class: "auth-submit" %>
      <% end %>

      <div class="auth-password-info">
        <i class="fa-solid fa-envelope"></i>
        <p>
          Si un compte existe avec cette adresse, vous recevrez un e-mail avec les instructions.
        </p>
      </div>

      <div class="auth-footer">
        <p>
          Vous avez retrouvé votre mot de passe ?
          <%= link_to "Se connecter", new_session_path(resource_name), class: "auth-link" %>
        </p>
      </div>
    </div>
  </section>
</div>
