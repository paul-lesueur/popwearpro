<div class="devise-page">

  <div class="devise-page__brand">
    <div>
      <h1>Popwear Pro</h1>
      <p>Gestion simplifiée pour artisans maroquiniers</p>
    </div>
  </div>

  <div class="devise-page__content">
    <div class="devise-card">

      <h1 class="devise-card__title">Changer le mot de passe</h1>

      <p class="devise-card__subtitle">
        Choisissez un nouveau mot de passe sécurisé.
      </p>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.error_notification %>

        <%= f.input :reset_password_token, as: :hidden %>
        <%= f.full_error :reset_password_token %>

        <div class="form-inputs">
          <%= f.input :password,
                      required: true,
                      autofocus: true,
                      label: false,
                      placeholder: "Nouveau mot de passe",
                      hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                      input_html: { autocomplete: "new-password" } %>

          <%= f.input :password_confirmation,
                      required: true,
                      label: false,
                      placeholder: "Confirmer le nouveau mot de passe",
                      input_html: { autocomplete: "new-password" } %>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Changer mon mot de passe" %>
        </div>
      <% end %>

      <div class="devise-card__links">
        <%= link_to "Se connecter", new_session_path(resource_name) %><br>
        <%= link_to "Créer un compte", new_registration_path(resource_name) %>
      </div>

    </div>
  </div>

</div>
