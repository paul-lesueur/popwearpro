<div class="sales-page">
  <div class="sales-header">
    <div>
      <h1>Ventes</h1>
      <p class="text-muted">Analysez vos performances financières et vos commandes encaissées.</p>

      <div class="sales-tabs">
        <%= link_to "Tableau de bord", sales_path(period: @period), class: "sales-tab is-active" %>
        <%= link_to "Transactions", sales_transactions_path, class: "sales-tab" %>
        <%= link_to "Catalogue", items_path, class: "sales-tab" %>
      </div>
    </div>

    <details class="sales-period-dropdown">
      <summary class="sales-period">
        <%= @period_label %>
        <i class="fa-solid fa-chevron-down"></i>
      </summary>

      <div class="sales-period-menu">
        <% @period_options.each do |value, label| %>
          <%= link_to label,
            sales_path(period: value),
            class: "sales-period-link #{'is-active' if @period == value}" %>
        <% end %>
      </div>
    </details>
  </div>

  <section class="sales-summary">
    <h2>Indicateurs clés</h2>

    <div class="sales-summary-grid">
      <div class="sales-summary-card">
        <div>
          <p class="sales-summary-value">
            <%= number_to_currency(@total_sales, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
          </p>
          <p class="sales-summary-label">Chiffre d’affaires encaissé</p>
          <p class="sales-summary-trend is-positive">
            <%= @orders_count %> commande<%= "s" if @orders_count > 1 %> payée<%= "s" if @orders_count > 1 %>
          </p>
        </div>

        <div class="sales-summary-icon">
          <i class="fa-solid fa-euro-sign"></i>
        </div>
      </div>

      <div class="sales-summary-card">
        <div>
          <p class="sales-summary-value">
            <%= number_to_currency(@average_order, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
          </p>
          <p class="sales-summary-label">Panier moyen</p>
          <p class="sales-summary-trend is-positive">Moyenne par commande encaissée</p>
        </div>

        <div class="sales-summary-icon">
          <i class="fa-solid fa-cart-shopping"></i>
        </div>
      </div>

      <div class="sales-summary-card">
        <div>
          <p class="sales-summary-value"><%= @weekly_orders_count %></p>
          <p class="sales-summary-label">Commandes cette semaine</p>
          <p class="sales-summary-trend is-positive">Suivi de l’activité récente</p>
        </div>

        <div class="sales-summary-icon">
          <i class="fa-solid fa-calendar-week"></i>
        </div>
      </div>

      <div class="sales-summary-card">
        <div>
          <p class="sales-summary-value"><%= @items_count %></p>
          <p class="sales-summary-label">Prestations au catalogue</p>
          <p class="sales-summary-trend is-positive">Prestations facturables actives</p>
        </div>

        <div class="sales-summary-icon">
          <i class="fa-solid fa-tags"></i>
        </div>
      </div>
    </div>
  </section>

  <section class="sales-dashboard-grid">
    <div class="sales-panel sales-week">
      <div class="sales-panel-header">
        <div>
          <h2>Chiffre d’affaires de la semaine</h2>

          <p>
            <strong><%= @weekly_orders_count %></strong>
            commandes encaissées
          </p>

          <p>
            <strong>
              <%= number_to_currency(@weekly_total, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
            </strong>
            générés cette semaine
          </p>
        </div>
      </div>

      <% max_weekly_sales = (@weekly_sales.map { |sale| sale[:value].to_f }.max || 0).to_f %>
      <% max_weekly_sales = 1 if max_weekly_sales.zero? %>

      <div class="sales-bars">
        <% @weekly_sales.each do |sale| %>
          <% bar_height = sale[:value].positive? ? ((sale[:value].to_f / max_weekly_sales) * 120).round : 6 %>

          <div class="sales-bar-item">
            <div class="sales-bar-wrapper">
              <span class="sales-bar-tooltip">
                <%= number_to_currency(sale[:value], unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
              </span>

              <div class="sales-bar" style="height: <%= bar_height %>px;"></div>
            </div>

            <span><%= sale[:day] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="sales-panel sales-orders-chart">
      <div class="sales-panel-header">
        <div>
          <h2>Commandes encaissées</h2>

          <div class="sales-chart-stats">
            <span>
              <strong><%= @current_period_orders_count %></strong>
              commandes — <%= @period_label %>
            </span>

            <span>
              <strong><%= @previous_period_orders_count %></strong>
              commandes — <%= @previous_period_label %>
            </span>
          </div>
        </div>

        <details class="sales-period-dropdown">
          <summary class="sales-period">
            <%= @period_label %>
            <i class="fa-solid fa-chevron-down"></i>
          </summary>

          <div class="sales-period-menu">
            <% @period_options.each do |value, label| %>
              <%= link_to label,
                sales_path(period: value),
                class: "sales-period-link #{'is-active' if @period == value}" %>
            <% end %>
          </div>
        </details>
      </div>

      <div class="sales-line-chart">
        <svg viewBox="0 0 680 220" preserveAspectRatio="none">
          <polyline points="<%= @previous_period_points %>" class="sales-line-muted" />
          <polyline points="<%= @current_period_points %>" class="sales-line-main" />
        </svg>

        <% if @best_period_day[:date].present? && @best_period_day[:count].positive? %>
          <div class="sales-chart-bubble">
            <strong>
              <%= @best_period_day[:count] %>
              commande<%= "s" if @best_period_day[:count] > 1 %>
            </strong>

            <span><%= l(@best_period_day[:date], format: "%d/%m/%Y") %></span>
          </div>
        <% end %>
      </div>

      <div class="sales-chart-legend">
        <span><i></i> <%= @previous_period_label %></span>
        <span><i></i> <%= @period_label %></span>
      </div>
    </div>

    <div class="sales-panel sales-best">
      <div class="sales-panel-header">
        <h2>Top prestations</h2>
      </div>

      <table>
        <thead>
          <tr>
            <th>Prestation</th>
            <th class="sales-table-price">Prix</th>
            <th class="sales-table-number">Unités vendues</th>
          </tr>
        </thead>

        <tbody>
          <% if @best_sales.any? %>
            <% @best_sales.each do |sale| %>
              <tr>
                <td>
                  <div class="sales-product">
                    <span class="catalog-icon-halo sales-product-icon-halo">
                      <%= catalog_icon(sale[:icon]) %>
                    </span>

                    <span class="sales-product-name"><%= sale[:name] %></span>
                  </div>
                </td>

                <td class="sales-table-price">
                  <%= number_to_currency(sale[:price], unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                </td>

                <td class="sales-table-number">
                  <%= sale[:units] %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3">Aucune prestation vendue pour le moment.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="sales-panel sales-highlight">
      <div class="sales-panel-header">
        <h2>Performance</h2>
      </div>

      <% if @best_period_day[:date].present? && @best_period_day[:count].positive? %>
        <div class="sales-highlight-hero">
          <div class="sales-highlight-icon">
            <i class="fa-solid fa-trophy"></i>
          </div>

          <div>
            <span>Meilleur jour</span>

            <strong>
              <%= @best_period_day[:count] %>
              commande<%= "s" if @best_period_day[:count] > 1 %>
            </strong>

            <p><%= l(@best_period_day[:date], format: "%d %B %Y") %></p>
          </div>
        </div>
      <% else %>
        <div class="sales-highlight-empty">
          <i class="fa-solid fa-chart-line"></i>
          <strong>Aucune tendance disponible</strong>
          <span>Les temps forts apparaîtront avec les prochaines commandes encaissées.</span>
        </div>
      <% end %>

      <div class="sales-highlight-grid">
        <div class="sales-highlight-card">
          <span>Période actuelle</span>
          <strong><%= @current_period_orders_count %></strong>
          <p><%= @period_label %></p>
        </div>

        <div class="sales-highlight-card">
          <span>Période précédente</span>
          <strong><%= @previous_period_orders_count %></strong>
          <p><%= @previous_period_label %></p>
        </div>
      </div>
    </div>
  </section>
</div>
