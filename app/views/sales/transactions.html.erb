<div class="sales-page">
  <div class="sales-header">
    <div>
      <h1>Transactions</h1>
      <p class="text-muted">Consultez l’historique des encaissements et le détail des commandes payées.</p>

      <div class="sales-tabs">
        <%= link_to "Tableau de bord", sales_path, class: "sales-tab" %>
        <%= link_to "Transactions", sales_transactions_path, class: "sales-tab is-active" %>
        <%= link_to "Catalogue", items_path, class: "sales-tab" %>
      </div>
    </div>
  </div>

  <section class="sales-transactions-clean">
    <div class="sales-transactions-toolbar">
      <%= form_with url: sales_transactions_path,
                    method: :get,
                    class: "sales-transactions-search",
                    data: { turbo: false } do %>
        <%= hidden_field_tag :page, 1 %>

        <div class="sales-search-field">
          <i class="fa-solid fa-magnifying-glass"></i>

          <%= text_field_tag :query,
            @query,
            placeholder: "Rechercher un client ou N° de commande...",
            autocomplete: "off"
          %>
        </div>
      <% end %>

      <details class="sales-export-dropdown">
        <summary class="sales-report-btn">
          <i class="fa-solid fa-download"></i>
          Rapport
        </summary>

        <div class="sales-export-panel">
          <p class="sales-export-title">Télécharger un rapport</p>

          <%= form_with url: sales_report_path(format: :csv),
                        method: :get,
                        class: "sales-export-form",
                        data: { turbo: false } do %>
            <%= hidden_field_tag :query, @query %>

            <div class="sales-export-date">
              <label for="start_date">Date de début</label>
              <%= date_field_tag :start_date, @export_start_date %>
            </div>

            <div class="sales-export-date">
              <label for="end_date">Date de fin</label>
              <%= date_field_tag :end_date, @export_end_date %>
            </div>

            <button type="submit" class="sales-export-submit">
              <i class="fa-solid fa-file-arrow-down"></i>
              Exporter le rapport
            </button>
          <% end %>
        </div>
      </details>
    </div>

    <div class="sales-transactions-layout">
      <div class="sales-clean-table sales-clean-table--card">
        <div class="sales-clean-table-head">
          <div>Référence</div>
          <div>Client</div>
          <div class="sales-cell-right">Total TTC</div>
          <div>Paiement</div>
        </div>

        <% if @transactions_by_date.any? %>
          <% @transactions_by_date.each do |date, transactions| %>
            <% day_total = transactions.sum { |transaction| transaction[:total] } %>

            <div class="sales-transaction-day">
              <span>
                <% if date == Date.current %>
                  Aujourd’hui
                <% else %>
                  <%= l(date, format: "%d %B %Y") %>
                <% end %>
              </span>

              <strong>
                <%= number_to_currency(day_total, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
              </strong>
            </div>

            <% transactions.each do |transaction| %>
              <% order = transaction[:order] %>

              <%= link_to sales_transactions_path(request.query_parameters.merge(order_id: order.id)),
                class: "sales-clean-row #{'is-selected' if @selected_order == order}" do %>

                <div class="sales-reference">
                  <strong><%= transaction[:reference].to_s.sub("Commande ", "") %></strong>
                  <span>Commande</span>
                </div>

                <div class="sales-customer-cell">
                  <strong><%= transaction[:customer_name] %></strong>
                  <span>Client</span>
                </div>

                <div class="sales-amount-cell">
                  <%= number_to_currency(transaction[:total], unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                </div>

                <div>
                  <span class="sales-payment-badge">
                    <%= transaction[:payment_method] %>
                  </span>
                </div>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <div class="sales-clean-empty">
            Aucune transaction trouvée.
          </div>
        <% end %>
      </div>

      <aside class="sales-transaction-detail">
        <% if @selected_order.present? %>
          <% customer = @selected_order.customer %>

          <div class="sales-detail-header">
            <div>
              <p>Détail de la transaction</p>
              <h2>Commande <%= order_reference(@selected_order) %></h2>
            </div>

            <%= link_to sales_transactions_path(request.query_parameters.except(:order_id)), class: "sales-detail-close" do %>
              <i class="fa-solid fa-xmark"></i>
            <% end %>
          </div>

          <div class="sales-detail-block">
            <span class="sales-detail-label">Client</span>
            <strong><%= customer_name(customer) %></strong>

            <% if customer.present? && !customer.is_anonymous? %>
              <small><%= customer.phone.presence || customer.email.presence || "Aucun contact renseigné" %></small>
            <% end %>
          </div>

          <div class="sales-detail-block">
            <span class="sales-detail-label">Date</span>
            <strong><%= l(@selected_order.created_at, format: "%d/%m/%Y") %></strong>
          </div>

          <div class="sales-detail-block">
            <span class="sales-detail-label">Paiement</span>
            <strong><%= payment_method_label(@selected_order.payment_method) %></strong>
            <small><%= payment_status_label(@selected_order.payment_status) %></small>
          </div>

          <div class="sales-detail-lines">
            <span class="sales-detail-label">Prestations facturées</span>

            <% @selected_order.order_lines.each do |line| %>
              <% quantity = line.quantity.to_i.zero? ? 1 : line.quantity.to_i %>

              <div class="sales-detail-line">
                <div>
                  <strong><%= line.item.name %></strong>

                  <small>
                    <%= quantity %> ×
                    <%= number_to_currency(line.unit_price_ht, unit: "€ HT", separator: ",", delimiter: " ", format: "%n %u") %>
                  </small>
                </div>

                <span>
                  <%= number_to_currency(line_total_ttc(line), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                </span>
              </div>
            <% end %>
          </div>

          <% if @selected_order.discount.to_f.positive? %>
            <div class="sales-detail-total-line">
              <span>Remise</span>

              <strong>
                -<%= number_to_currency(@selected_order.discount, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
              </strong>
            </div>
          <% end %>

          <div class="sales-detail-total">
            <span>Total TTC</span>

            <strong>
              <%= number_to_currency(order_total_ttc(@selected_order), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
            </strong>
          </div>

          <%= link_to order_path(@selected_order), class: "sales-detail-order-link" do %>
            Ouvrir la commande complète
            <i class="fa-solid fa-arrow-right"></i>
          <% end %>
        <% else %>
          <div class="sales-detail-empty">
            <i class="fa-solid fa-receipt"></i>
            <strong>Sélectionnez une transaction</strong>
            <span>Le détail de la commande s’affichera ici.</span>
          </div>
        <% end %>
      </aside>
    </div>

    <% if @total_pages > 1 %>
      <div class="sales-clean-pagination">
        <div class="sales-pages">
          <% if @page > 1 %>
            <%= link_to "‹", sales_transactions_path(request.query_parameters.merge(page: @page - 1)) %>
          <% else %>
            <span class="disabled">‹</span>
          <% end %>

          <% (1..@total_pages).each do |page_number| %>
            <% if page_number == @page %>
              <span class="current"><%= page_number %></span>
            <% else %>
              <%= link_to page_number, sales_transactions_path(request.query_parameters.merge(page: page_number)) %>
            <% end %>
          <% end %>

          <% if @page < @total_pages %>
            <%= link_to "›", sales_transactions_path(request.query_parameters.merge(page: @page + 1)) %>
          <% else %>
            <span class="disabled">›</span>
          <% end %>
        </div>

        <div class="sales-results-count">
          <%= @transactions_count %> résultat<%= "s" if @transactions_count > 1 %>
        </div>
      </div>
    <% end %>
  </section>
</div>
