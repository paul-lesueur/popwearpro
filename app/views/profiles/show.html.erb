<div class="profile-page-wrapper">
  <div class="profile-page">

    <div class="profile-page-title">
      <h1>Mon profil</h1>
      <p>Gérez vos informations personnelles et vos paramètres de compte.</p>
    </div>

    <div class="profile-header">
      <div class="profile-header__avatar">
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "profile-header__avatar-image" %>
        <% else %>
          <%= user_initials(current_user) %>
        <% end %>
      </div>

      <div>
        <h2 class="profile-header__name"><%= current_user.name.presence || current_user.email %></h2>
        <p class="profile-header__email"><%= current_user.email %></p>
      </div>
    </div>

    <%= form_with model: current_user, url: profile_path, method: :patch do |f| %>

      <div class="profile-card">
        <h2 class="profile-card__title">Compte utilisateur</h2>

        <% if current_user.errors.any? %>
          <div class="alert alert-danger mb-4">
            <ul class="mb-0">
              <% current_user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="profile-inline-row">
          <p class="profile-inline-row__label">Photo de profil</p>

          <label class="profile-upload-button">
            Changer
            <%= f.file_field :avatar, class: "profile-file-input-hidden", accept: "image/png,image/jpeg,image/jpg,image/webp" %>
          </label>
        </div>

        <div class="profile-field">
          <%= f.label :name, "Nom", class: "profile-field__label" %>
          <%= f.text_field :name, class: "profile-field__input", placeholder: "Votre nom" %>
        </div>
      </div>

      <div class="profile-card">
        <h2 class="profile-card__title">Sécurité</h2>

        <details class="profile-password-details">
          <summary class="profile-password-toggle">
            <span>Modifier mon adresse e-mail</span>
            <i class="fa-solid fa-chevron-down"></i>
          </summary>

          <div class="profile-password-fields">
            <div class="profile-field">
              <%= f.label :email, "Nouvelle adresse e-mail", class: "profile-field__label" %>
              <%= f.email_field :email, class: "profile-field__input" %>
            </div>
          </div>
        </details>

        <details class="profile-password-details">
          <summary class="profile-password-toggle">
            <span>Modifier mon mot de passe</span>
            <i class="fa-solid fa-chevron-down"></i>
          </summary>

          <div class="profile-password-fields">
            <p class="profile-card__hint">Renseignez ces champs uniquement si vous souhaitez modifier votre mot de passe.</p>

            <div class="profile-field">
              <%= f.label :current_password, "Mot de passe actuel", class: "profile-field__label" %>
              <%= f.password_field :current_password, class: "profile-field__input", autocomplete: "current-password" %>
            </div>

            <div class="profile-field">
              <%= f.label :password, "Nouveau mot de passe", class: "profile-field__label" %>
              <%= f.password_field :password, class: "profile-field__input", autocomplete: "new-password" %>
            </div>

            <div class="profile-field">
              <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "profile-field__label" %>
              <%= f.password_field :password_confirmation, class: "profile-field__input", autocomplete: "new-password" %>
            </div>
          </div>
        </details>
      </div>

      <div class="profile-actions">
        <%= f.submit "Enregistrer les modifications", class: "profile-primary-button" %>
      </div>

    <% end %>

  </div>
</div>
