<turbo-frame id="order-detail">
<div class="order-modal">
  <div class="d-flex justify-content-between align-items-start mb-4">
    <h2 class="mb-0">Commande #<%= @order.id %></h2>
    <div class="d-flex gap-2 align-items-center">
      <button type="button" class="btn-wiz btn-wiz--ghost" data-action="click->modal#close"><i class="fa-solid fa-xmark"></i>Fermer</button>
      <%= link_to edit_order_path(@order), class: "btn-wiz btn-wiz--primary", data: { turbo_frame: "_top" } do %>
        <i class="fa-solid fa-pencil"></i>Modifier
      <% end %>
    </div>
  </div>

  <%# Conteneur des flashes de confirmation (les réponses Turbo Stream y insèrent). %>
  <% flash_variants = { "notice" => "success", "success" => "success", "info" => "info", "alert" => "error", "error" => "error" } %>
  <div id="order_flash_<%= @order.id %>">
    <% flash.each do |type, message| %>
      <%= render "orders/modal_flash", variant: (flash_variants[type.to_s] || "info"), message: message %>
    <% end %>
  </div>

  <%# Suggestions (UC2 prête / UC3 rappel J+3-J+10 / UC4 date imminente-dépassée) %>
  <%= render "orders/suggestions", order: @order %>

  <%# Client %>
  <h5 class="fw-bold text-secondary mb-2">Client</h5>
  <p class="text-muted mb-4"><%= @order.customer.display_name %></p>

  <hr style="border-color: #EAE4DF;">

  <%# Statut de la commande %>
  <h5 class="fw-bold text-secondary mb-3">Statut de la commande</h5>
  <% status_labels = {
    "pending"     => "Nouvelle commande",
    "in_progress" => "En cours",
    "sent"        => "En attente de retrait",
    "completed"   => "Terminée",
    "delivered"   => "Terminée"
  } %>
  <% payment_method_labels = { "card" => "Carte bancaire", "cash" => "Espèces", "check" => "Chèque", "bank_transfer" => "Virement", "other" => "Autre" } %>
  <% payment_status_labels = { "unpaid" => "En attente de paiement", "paid" => "Payé" } %>
  <%# Couleurs alignées sur les colonnes du kanban (cf. badge_styles dans index). %>
  <% status_badge_classes = { "pending" => "bg-gradient-green", "in_progress" => "bg-gradient-orange", "sent" => "bg-warning" } %>
  <% status_done = %w[completed delivered].include?(@order.status) %>
  <div class="d-flex flex-wrap gap-2 mb-4">
    <%# Tag statut de la commande (même couleur que la colonne kanban) %>
    <span class="badge px-3 py-2 align-self-start text-white d-inline-flex align-items-center gap-1 <%= status_badge_classes[@order.status] %>"
          style="<%= "background: #411221;" if status_done %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
      </svg>
      <%= status_labels[@order.status] || @order.status %>
    </span>
  </div>

  <hr style="border-color: #EAE4DF;">

  <%# Prestations %>
  <h5 class="fw-bold text-secondary mb-3 mt-4">Prestations</h5>
  <% if @order.order_lines.any? %>
    <ul class="text-muted mb-0 ps-3">
      <% @order.order_lines.each do |line| %>
        <li class="mb-1"><%= line.item.name %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">Aucune prestation.</p>
  <% end %>

  <hr style="border-color: #EAE4DF;">

  <%# Paiement %>
  <h5 class="fw-bold text-secondary mb-3 mt-4">Paiement</h5>
  <% total_ht = @order.total_ht %>
  <% total_ttc = @order.total_ttc %>
  <% tva = total_ttc - total_ht %>
  <%# Largeur contrainte : les montants restent vers le milieu du modal élargi. %>
  <div class="mb-3" style="max-width: 460px;">
    <div class="d-flex justify-content-between mb-1">
      <span class="text-muted">Sous-total</span>
      <span class="text-muted"><%= number_to_currency(total_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> HT</span>
    </div>
    <div class="d-flex justify-content-between mb-1">
      <span class="text-muted">TVA</span>
      <span class="text-muted"><%= number_to_currency(tva, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></span>
    </div>
    <% if @order.discount.to_f.positive? %>
      <div class="d-flex justify-content-between mb-1">
        <span class="text-muted">Réduction</span>
        <span class="text-muted">− <%= number_to_currency(@order.discount, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></span>
      </div>
    <% end %>
    <div class="d-flex justify-content-between mt-2 pt-2" style="border-top: 1px solid #EAE4DF;">
      <span class="fw-bold">Montant total</span>
      <span class="fw-bold text-secondary"><%= number_to_currency(@order.total_due, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> TTC</span>
    </div>
  </div>

  <%# Tags paiement (sous le montant) : modalité puis moyen de paiement %>
  <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-2">
    <%# Modalité de paiement : orange (en attente) / vert (payé) %>
    <% if @order.payment_status.present? %>
      <% paid = @order.payment_status == "paid" %>
      <span class="badge px-3 py-2 <%= paid ? "bg-gradient-green" : "bg-warning" %> text-white d-inline-flex align-items-center gap-1">
        <% if paid %>
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
          </svg>
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
          </svg>
        <% end %>
        <%= payment_status_labels[@order.payment_status] || @order.payment_status %>
      </span>
    <% end %>

    <%# Moyen de paiement : tag neutre %>
    <% if @order.payment_method.present? %>
      <span class="badge px-3 py-2 bg-secondary text-white d-inline-flex align-items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
          <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
        </svg>
        <%= payment_method_labels[@order.payment_method] || @order.payment_method %>
      </span>
    <% end %>
  </div>

  <hr style="border-color: #EAE4DF;">

  <%# Informations %>
  <h5 class="fw-bold text-secondary mb-3 mt-4">Informations</h5>
  <p class="fw-semibold mb-1">Date de retrait</p>
  <p class="text-muted"><%= @order.due_date.present? ? l(@order.due_date, format: :long) : "Date à fixer" %></p>
  <p class="fw-semibold mb-1">Commentaires</p>
  <p class="text-muted"><%= @order.internal_notes.presence || "Aucun commentaire." %></p>

  <hr style="border-color: #EAE4DF;">

  <%# Historique %>
  <%= render "orders/history", order: @order %>

  <hr style="border-color: #EAE4DF;">

  <%# Communication client : rappel SMS activable par commande %>
  <h5 class="fw-bold text-secondary mb-3 mt-4">Communication client</h5>
  <div class="d-flex justify-content-between align-items-center gap-3">
    <div>
      <p class="fw-semibold mb-0">Rappel SMS au client</p>
      <p class="text-muted small mb-0">Prévenir automatiquement le client par SMS lorsque la commande est prête.</p>
    </div>
    <%# Toggle slider (même visuel que le formulaire de création) : le submit
        bascule sms_reminder côté serveur, puis le frame se recharge. %>
    <%= form_with url: toggle_reminder_order_path(@order), method: :patch, class: "mb-0 flex-shrink-0" do %>
      <button type="submit"
              class="w-toggle <%= "is-on" if @order.sms_reminder? %>"
              role="switch"
              aria-checked="<%= @order.sms_reminder? %>"
              aria-label="Activer le rappel SMS au client"></button>
    <% end %>
  </div>
</div>
</turbo-frame>
