<% ai_client_messages = @ai_client_messages || @order.communications.where(purpose: "ai_client_message").order(created_at: :desc) %>
<% sent_messages = ai_client_messages.select { |communication| communication.status == "sent" } %>
<% latest_message = ai_client_messages.first %>
<% overlay_id = "ai-client-message-overlay-#{@order.id}" %>
<% open_overlay = params[:open_ai_message] == "1" %>

<%
  latest_content = latest_message&.content.to_s
  subject_line = latest_content.lines.find { |line| line.strip.start_with?("Objet") }&.strip
  subject = subject_line&.sub(/^Objet\s*:\s*/i, "") || latest_message&.kind_label || "Message client"
  body = latest_content.lines.reject { |line| line.strip.start_with?("Objet") }.join.strip
%>

<style>
  .ai-client-card {
    background: #fff;
    border: 1px solid #f1e6df;
    border-radius: 14px;
    padding: 9px 10px;
    margin-bottom: 10px;
    box-shadow: 0 6px 16px rgba(74, 29, 29, 0.04);
  }

  .ai-client-compact-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-client-card .ai-client-icon {
    width: 28px;
    height: 28px;
    border-radius: 10px;
    background: linear-gradient(135deg, #ff6b35, #ff8a5c);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 6px 14px rgba(255, 107, 53, 0.18);
  }

  .ai-client-card .ai-client-icon svg {
    width: 13px;
    height: 13px;
  }

  .ai-client-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background: linear-gradient(135deg, #ff6b35, #ff8a5c);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 8px 18px rgba(255, 107, 53, 0.2);
  }

  .ai-client-title {
    margin: 0;
    color: #4a1d1d;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.1;
  }

  .ai-client-subtitle {
    margin: 1px 0 0;
    color: #9b8c87;
    font-size: 10.5px;
    line-height: 1.2;
  }

  .ai-client-open-button {
    border: none;
    border-radius: 10px;
    padding: 6px 9px;
    background: #fff1e8;
    color: #e85f2e;
    font-weight: 800;
    font-size: 10.5px;
    cursor: pointer;
    white-space: nowrap;
    margin-left: auto;
  }

  .ai-client-open-button:hover {
    background: #ffe8d8;
  }

  .ai-client-status-line {
    margin-top: 7px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: #faf8f6;
    border: 1px solid #f0e6df;
    border-radius: 10px;
    padding: 6px 8px;
  }

  .ai-client-status-title {
    margin: 0;
    color: #4a1d1d;
    font-size: 11px;
    font-weight: 800;
    line-height: 1.15;
  }

  .ai-client-status-meta {
    margin: 1px 0 0;
    color: #9b8c87;
    font-size: 9.5px;
    line-height: 1.15;
  }

  .ai-client-success-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #20c277;
    flex-shrink: 0;
  }

  .ai-client-overlay {
    position: fixed;
    inset: 0;
    z-index: 999999;
    background: rgba(42, 28, 28, 0.42);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .ai-client-overlay[hidden] {
    display: none !important;
  }

  .ai-client-modal {
    width: min(520px, calc(100vw - 32px));
    max-height: 78vh;
    overflow-y: auto;
    background: #fffaf7;
    border-radius: 24px;
    box-shadow: 0 28px 90px rgba(74, 29, 29, 0.28);
    color: #4a1d1d;
  }

  .ai-client-modal::-webkit-scrollbar,
  .ai-client-edit-area::-webkit-scrollbar {
    width: 6px;
  }

  .ai-client-modal::-webkit-scrollbar-track,
  .ai-client-edit-area::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-client-modal::-webkit-scrollbar-thumb,
  .ai-client-edit-area::-webkit-scrollbar-thumb {
    background: #d8c4b8;
    border-radius: 999px;
  }

  .ai-client-modal-top {
    padding: 18px 20px 14px;
    border-bottom: 1px solid #f2e6dd;
    background:
      radial-gradient(circle at top left, rgba(255, 107, 53, 0.14), transparent 36%),
      #fffaf7;
  }

  .ai-client-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .ai-client-modal-identity {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .ai-client-modal-identity .ai-client-title {
    font-size: 15px;
  }

  .ai-client-modal-identity .ai-client-subtitle {
    font-size: 12px;
  }

  .ai-client-close {
    border: none;
    background: #fff;
    color: #7b6868;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    font-size: 19px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 6px 16px rgba(74, 29, 29, 0.08);
  }

  .ai-client-context-box {
    margin: 12px 18px 0;
    background: #fff;
    border: 1px solid #f0e6df;
    border-radius: 17px;
    padding: 12px;
  }

  .ai-client-context-label {
    margin: 0 0 3px;
    color: #e85f2e;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 900;
  }

  .ai-client-context-title {
    margin: 0 0 10px;
    color: #4a1d1d;
    font-size: 14px;
    font-weight: 800;
  }

  .ai-client-choice-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 7px;
    margin-bottom: 12px;
  }

  .ai-client-choice {
    border: 1px solid #f0d4c6;
    background: #fff8f4;
    color: #7a3b28;
    border-radius: 13px;
    padding: 8px 8px;
    font-size: 11px;
    font-weight: 900;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 40px;
    text-align: center;
    transition: all 0.15s ease;
  }

  .ai-client-choice:hover {
    background: #fff1e8;
    border-color: #ffb08a;
  }

  .ai-client-choice input {
    display: none;
  }

  .ai-client-choice:has(input:checked) {
    background: linear-gradient(135deg, #ff6b35, #e85f2e);
    color: #fff;
    border-color: #ff6b35;
    box-shadow: 0 8px 18px rgba(255, 107, 53, 0.16);
  }

  .ai-client-choice-icon {
    width: 18px;
    height: 18px;
    border-radius: 999px;
    background: rgba(255, 107, 53, 0.1);
    color: #e85f2e;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-client-choice:has(input:checked) .ai-client-choice-icon {
    background: rgba(255, 255, 255, 0.24);
    color: #fff;
  }

  .ai-client-choice-icon svg {
    width: 11px;
    height: 11px;
  }

  .ai-client-generate {
    width: 100%;
    border: none;
    border-radius: 13px;
    padding: 11px;
    background: linear-gradient(135deg, #ff6b35, #e85f2e);
    color: #fff;
    font-weight: 900;
    box-shadow: 0 12px 26px rgba(255, 107, 53, 0.22);
  }

  .ai-client-modal-body {
    padding: 14px 18px 18px;
  }

  .ai-client-empty {
    margin: 0;
    color: #9b8c87;
    font-size: 14px;
  }

  .ai-client-draft {
    background: #fff;
    border: 1px solid #ff6b35;
    border-radius: 18px;
    padding: 13px;
  }

  .ai-client-draft-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .ai-client-draft-title {
    margin: 0;
    color: #e85f2e;
    font-size: 13px;
    font-weight: 900;
  }

  .ai-client-draft-badge {
    background: #fff3c4;
    color: #9a7400;
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 10px;
    font-weight: 800;
    white-space: nowrap;
  }

  .ai-client-mail-line {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 8px;
    border-bottom: 1px solid #f0e6df;
    padding: 7px 0;
    font-size: 12px;
  }

  .ai-client-mail-label {
    color: #a99c99;
  }

  .ai-client-subject {
    color: #4a1d1d;
    font-weight: 800;
  }

  .ai-client-edit-area {
    width: 100%;
    min-height: 125px;
    max-height: 180px;
    border: none;
    resize: vertical;
    background: transparent;
    color: #4a1d1d;
    margin: 12px 0 0;
    line-height: 1.45;
    font-size: 13px;
    font-family: inherit;
  }

  .ai-client-edit-area:focus {
    outline: none;
  }

  .ai-client-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 12px;
  }

  .ai-client-action {
    border: none;
    border-radius: 13px;
    padding: 8px 10px;
    font-size: 12px;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    cursor: pointer;
  }

  .ai-client-action-light {
    background: #fff8f4;
    color: #7a3b28;
    border: 1px solid #f0d4c6;
  }

  .ai-client-action-light:hover {
    background: #fff1e8;
  }

  .ai-client-action-primary {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, #ff6b35, #e85f2e);
    color: #fff;
    box-shadow: 0 10px 22px rgba(255, 107, 53, 0.22);
  }

  .ai-client-action-icon {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-client-action-light .ai-client-action-icon {
    background: #fff;
    color: #e85f2e;
  }

  .ai-client-action-primary .ai-client-action-icon {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
  }

  .ai-client-action-icon svg {
    width: 13px;
    height: 13px;
  }

  .ai-client-history {
    margin-top: 12px;
    border-top: 1px solid #f0e6df;
    padding-top: 12px;
  }

  .ai-client-history-title {
    margin: 0 0 8px;
    color: #4a1d1d;
    font-size: 12px;
    font-weight: 900;
  }

  .ai-client-history-list {
    display: grid;
    gap: 8px;
  }

  .ai-client-history-item {
    background: #fff;
    border: 1px solid #f0e6df;
    border-radius: 14px;
    padding: 10px 12px;
  }

  .ai-client-history-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .ai-client-history-kind {
    margin: 0;
    color: #4a1d1d;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.25;
  }

  .ai-client-history-meta {
    margin: 3px 0 0;
    color: #9b8c87;
    font-size: 11px;
    line-height: 1.25;
  }

  .ai-client-history-badge {
    border-radius: 999px;
    padding: 4px 8px;
    font-size: 10px;
    font-weight: 900;
    white-space: nowrap;
  }

  .ai-client-history-badge--sent {
    background: #ddf7ea;
    color: #157347;
  }

  @media (max-width: 640px) {
    .ai-client-choice-list {
      grid-template-columns: 1fr;
    }

    .ai-client-modal {
      width: calc(100vw - 24px);
      max-height: 88vh;
    }

    .ai-client-actions {
      grid-template-columns: 1fr;
    }

    .ai-client-action-primary {
      grid-column: auto;
    }
  }
</style>

<section class="ai-client-card">
  <div class="ai-client-compact-row">
    <span class="ai-client-icon">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 3L13.7 8.3L19 10L13.7 11.7L12 17L10.3 11.7L5 10L10.3 8.3L12 3Z" fill="currentColor"/>
        <path d="M18 15L18.8 17.2L21 18L18.8 18.8L18 21L17.2 18.8L15 18L17.2 17.2L18 15Z" fill="currentColor"/>
      </svg>
    </span>

    <div>
      <h5 class="ai-client-title">Message client</h5>
      <p class="ai-client-subtitle">
        Brouillon IA
      </p>
    </div>

    <button type="button"
            class="ai-client-open-button"
            onclick="document.getElementById('<%= overlay_id %>').hidden = false;">
      Nouveau
    </button>
  </div>

  <% if latest_message.present? %>
    <div class="ai-client-status-line">
      <div>
        <p class="ai-client-status-title">
          <%= latest_message.kind_label %>
        </p>

        <p class="ai-client-status-meta">
          <%= l(latest_message.created_at, format: :short) %>
        </p>
      </div>

      <span class="ai-client-success-dot"></span>
    </div>
  <% end %>
</section>

<div id="<%= overlay_id %>"
     class="ai-client-overlay"
     <%= "hidden" unless open_overlay %>
     onclick="if (event.target === this) this.hidden = true;">
  <div class="ai-client-modal">
    <div class="ai-client-modal-top">
      <div class="ai-client-modal-header">
        <div class="ai-client-modal-identity">
          <span class="ai-client-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M12 3L13.7 8.3L19 10L13.7 11.7L12 17L10.3 11.7L5 10L10.3 8.3L12 3Z" fill="currentColor"/>
              <path d="M18 15L18.8 17.2L21 18L18.8 18.8L18 21L17.2 18.8L15 18L17.2 17.2L18 15Z" fill="currentColor"/>
            </svg>
          </span>

          <div>
            <h5 class="ai-client-title">Message client</h5>
            <p class="ai-client-subtitle">
              <%= @order.customer.firstname %> <%= @order.customer.lastname %>
              · Commande #<%= @order.id %>
            </p>
          </div>
        </div>

        <button type="button"
                class="ai-client-close"
                onclick="document.getElementById('<%= overlay_id %>').hidden = true;">
          ×
        </button>
      </div>
    </div>

    <div class="ai-client-context-box">
      <p class="ai-client-context-label">
        Contexte utilisé par l’IA
      </p>

      <h6 class="ai-client-context-title">
        Commande #<%= @order.id %>
      </h6>

      <%= form_with url: order_communications_path(@order),
                    method: :post,
                    data: { turbo_frame: "order-detail" } do %>

        <div class="ai-client-choice-list">
          <label class="ai-client-choice">
            <%= radio_button_tag "communication[kind]", "ready", true %>

            <span class="ai-client-choice-icon">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M9.2 16.6L4.9 12.3L3.5 13.7L9.2 19.4L20.5 8.1L19.1 6.7L9.2 16.6Z" fill="currentColor"/>
              </svg>
            </span>

            Commande prête
          </label>

          <label class="ai-client-choice">
            <%= radio_button_tag "communication[kind]", "retard" %>

            <span class="ai-client-choice-icon">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M12 2A10 10 0 1 0 12 22A10 10 0 0 0 12 2ZM12 20A8 8 0 1 1 12 4A8 8 0 0 1 12 20ZM12.5 7H11V13L16.2 16.1L17 14.8L12.5 12.1V7Z" fill="currentColor"/>
              </svg>
            </span>

            Prévenir retard
          </label>

          <label class="ai-client-choice">
            <%= radio_button_tag "communication[kind]", "information_needed" %>

            <span class="ai-client-choice-icon">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M11 18H13V16H11V18ZM12 2A10 10 0 1 0 12 22A10 10 0 0 0 12 2ZM12 20A8 8 0 1 1 12 4A8 8 0 0 1 12 20ZM12 6A3.2 3.2 0 0 0 8.8 9.2H10.8A1.2 1.2 0 1 1 12.8 10.1C11.4 11 11 11.8 11 14H13C13 12.6 13.3 12.2 14.2 11.6A3.1 3.1 0 0 0 12 6Z" fill="currentColor"/>
              </svg>
            </span>

            Demander info
          </label>
        </div>

        <%= submit_tag "Générer le message IA", class: "ai-client-generate" %>
      <% end %>
    </div>

    <div class="ai-client-modal-body">
      <% if latest_message.present? %>
        <div class="ai-client-draft">
          <div class="ai-client-draft-head">
            <p class="ai-client-draft-title">
              Message rédigé par l’IA
            </p>

            <span class="ai-client-draft-badge">
              Brouillon à valider
            </span>
          </div>

          <%= form_with url: order_communication_path(@order, latest_message),
                        method: :patch,
                        data: { turbo_frame: "order-detail" } do %>

            <%= hidden_field_tag "communication[subject]", subject %>

            <div class="ai-client-mail-line">
              <span class="ai-client-mail-label">De</span>
              <span>
                Popwear · <%= @order.establishment.name %>
                <span class="text-muted">&lt;no-reply@popwear.com&gt;</span>
              </span>
            </div>

            <div class="ai-client-mail-line">
              <span class="ai-client-mail-label">À</span>
              <span>
                <%= @order.customer.firstname %> <%= @order.customer.lastname %>
                <% if @order.customer.email.present? %>
                  <span class="text-muted">&lt;<%= @order.customer.email %>&gt;</span>
                <% end %>
              </span>
            </div>

            <div class="ai-client-mail-line">
              <span class="ai-client-mail-label">Objet</span>
              <span class="ai-client-subject"><%= subject %></span>
            </div>

            <%= text_area_tag "communication[body]",
              body.presence || latest_message.content,
              class: "ai-client-edit-area" %>

            <div class="ai-client-actions">
              <button type="submit"
                      name="communication_action"
                      value="regenerate"
                      class="ai-client-action ai-client-action-light">
                <span class="ai-client-action-icon">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M4 12A8 8 0 0 1 17.7 6.3L20 4V10H14L16.2 7.8A6 6 0 1 0 18 12H20A8 8 0 1 1 4 12Z" fill="currentColor"/>
                  </svg>
                </span>
                Régénérer
              </button>

              <button type="submit"
                      name="communication_action"
                      value="save"
                      class="ai-client-action ai-client-action-light">
                <span class="ai-client-action-icon">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M4 17.5V20H6.5L17.8 8.7L15.3 6.2L4 17.5ZM19.7 6.8C20.1 6.4 20.1 5.8 19.7 5.4L18.6 4.3C18.2 3.9 17.6 3.9 17.2 4.3L16.2 5.3L18.7 7.8L19.7 6.8Z" fill="currentColor"/>
                  </svg>
                </span>
                Modifier
              </button>

              <button type="submit"
                      name="communication_action"
                      value="send"
                      class="ai-client-action ai-client-action-primary">
                <span class="ai-client-action-icon">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M3 20L22 12L3 4V10L15 12L3 14V20Z" fill="currentColor"/>
                  </svg>
                </span>
                Envoyer au client
              </button>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="ai-client-empty">
          Aucun message IA généré pour cette commande.
        </p>
      <% end %>

      <% if sent_messages.any? %>
        <div class="ai-client-history">
          <h6 class="ai-client-history-title">
            Historique des messages envoyés (<%= sent_messages.count %>)
          </h6>

          <div class="ai-client-history-list">
            <% sent_messages.each do |communication| %>
              <div class="ai-client-history-item">
                <div class="ai-client-history-row">
                  <div>
                    <p class="ai-client-history-kind">
                      <%= communication.kind_label %>
                    </p>

                    <p class="ai-client-history-meta">
                      Envoyé le <%= l(communication.sent_at || communication.updated_at, format: :short) %>
                      <% if communication.recipient_email.present? %>
                        · <%= communication.recipient_email %>
                      <% end %>
                    </p>
                  </div>

                  <span class="ai-client-history-badge ai-client-history-badge--sent">
                    Envoyé
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
