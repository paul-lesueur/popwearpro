<%= form_with model: @order, url: orders_path, method: :post, local: true, html: { class: "order-form" } do |form| %>
  <% if @order.errors.any? %>
    <div class="alert alert-danger">
      <strong>Erreur :</strong>
      <ul class="mb-0">
        <% @order.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Champs non présents dans la maquette : valeurs par défaut posées dans le contrôleur. %>
  <%= form.hidden_field :status %>
  <%= form.hidden_field :priority %>
  <%= form.hidden_field :payment_status %>

  <div data-controller="order-cart">
    <%# ---- HEADER ---- %>
    <div class="order-form__header">
      <div class="d-flex align-items-center gap-2">
        <%= link_to orders_path, class: "order-form__close", aria: { label: "Fermer" } do %>
          <i class="fa-solid fa-xmark"></i>
        <% end %>
        <h1 class="h3 mb-0">Créer une commande</h1>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Annuler", orders_path, class: "btn btn-outline-primary" %>
        <%= form.submit "Finaliser la commande", class: "btn btn-success" %>
      </div>
    </div>

    <%# ---- CLIENT ---- %>
    <section class="order-form__section" data-controller="customer-field">
      <h2 class="order-form__title">Client</h2>
      <div class="row g-3 align-items-end">
        <div class="col-md-6">
          <%= form.label :customer_id, "Client", class: "form-label" %>
          <%= form.select :customer_id,
                @customers.map { |c| [c.display_name, c.id] },
                { prompt: "Sélectionner ou saisir" },
                class: "form-select",
                data: { customer_field_target: "select" } %>
        </div>
        <div class="col-md-3">
          <%= link_to "Ajouter un nouveau client", new_customer_path, class: "btn btn-outline-primary w-100" %>
        </div>
        <div class="col-md-3">
          <div class="form-check">
            <%= check_box_tag "order[anonymous]", "1", false,
                  class: "form-check-input", id: "order_anonymous",
                  data: { customer_field_target: "checkbox", action: "change->customer-field#toggle" } %>
            <label class="form-check-label" for="order_anonymous">Client anonyme</label>
          </div>
        </div>
      </div>
      <p class="text-subtext small mb-0 mt-2" data-customer-field-target="hint" hidden>
        Vente comptoir : un client anonyme (ANON-…) sera créé. Donne lieu à un reçu, pas à une facture nominative.
      </p>
    </section>

    <%# ---- PRESTATIONS (cartes cliquables) ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Prestations</h2>

      <div class="order-cards">
        <% @items.each do |item| %>
          <% ttc = item.price_ht.to_f * (1 + item.vat_rate.to_f / 100) %>
          <button type="button" class="order-card"
                  data-order-cart-target="card"
                  data-action="order-cart#toggle"
                  data-item-id="<%= item.id %>"
                  data-price-ht="<%= item.price_ht %>"
                  data-vat-rate="<%= item.vat_rate %>">
            <div class="order-card__media">
              <% if item.photo_url.present? %>
                <%= image_tag item.photo_url, class: "order-card__img", alt: item.name %>
              <% end %>
              <% if item.repair_bonus? %>
                <span class="order-card__bonus">Bonus réparation</span>
              <% end %>
              <span class="order-card__check"><i class="fa-solid fa-check"></i></span>
            </div>
            <div class="order-card__body">
              <div class="order-card__name"><%= item.name %></div>
              <div class="order-card__price">
                <%= number_to_currency(ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
              </div>
            </div>
          </button>
        <% end %>

        <%= link_to items_path, class: "order-card order-card--more" do %>
          <span>Voir le catalogue<br>des prestations</span>
        <% end %>
      </div>

      <%= link_to new_item_path, class: "btn btn-outline-primary mt-3" do %>
        Ajouter une prestation
      <% end %>

      <%# Conteneur (caché) des lignes sélectionnées : champs order_lines + pré-sélection. %>
      <div data-order-cart-target="lines" class="d-none">
        <% @order.order_lines.each_with_index do |line, i| %>
          <% next if line.item_id.blank? %>
          <div data-item-id="<%= line.item_id %>">
            <input type="hidden" name="order[order_lines_attributes][<%= i %>][item_id]" value="<%= line.item_id %>">
            <input type="hidden" name="order[order_lines_attributes][<%= i %>][quantity]" value="<%= line.quantity || 1 %>">
          </div>
        <% end %>
      </div>
    </section>

    <%# ---- PANIER (totaux live) ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Panier</h2>
      <div class="order-cart">
        <div class="order-cart__row">
          <span>Sous-total</span>
          <span data-order-cart-target="subtotal">0,00 €</span>
        </div>
        <div class="order-cart__row order-cart__row--muted">
          <span>Réduction</span>
          <span class="d-flex align-items-center gap-3">
            <span>0,00 €</span>
            <%# Décoratif / TODO : aucune gestion de réduction en base pour l'instant. %>
            <button type="button" class="btn btn-outline-primary btn-sm">Appliquer une réduction</button>
          </span>
        </div>
        <div class="order-cart__row">
          <span>TVA 20 %</span>
          <span data-order-cart-target="vat">0,00 €</span>
        </div>
        <div class="order-cart__row order-cart__row--total">
          <span>Montant total</span>
          <span data-order-cart-target="total">0,00 €</span>
        </div>
      </div>
    </section>

    <%# ---- PAIEMENT ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Paiement</h2>
      <div class="row g-3">
        <div class="col-md-6">
          <%# Décoratif / TODO : "modalités de paiement" non géré en base. %>
          <label class="form-label">Modalités de paiement</label>
          <select class="form-select">
            <option selected disabled>Sélectionner</option>
            <option>Comptant</option>
            <option>À la re-collecte</option>
          </select>
        </div>
        <div class="col-md-6">
          <%= form.label :payment_method, "Moyen de paiement", class: "form-label" %>
          <%= form.select :payment_method,
                [["Carte", "card"], ["Espèces", "cash"], ["Virement", "bank_transfer"], ["Autre", "other"]],
                { prompt: "Sélectionner" },
                class: "form-select" %>
        </div>
      </div>
    </section>

    <%# ---- INFORMATIONS ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Informations</h2>
      <div class="mb-3">
        <%= form.label :due_date, "Date de re-collecte", class: "form-label" %>
        <%= form.date_field :due_date, class: "form-control" %>
      </div>
      <div class="mb-0">
        <%= form.label :internal_notes, "Commentaires (optionnel)", class: "form-label" %>
        <%= form.text_area :internal_notes, rows: 3, class: "form-control",
              placeholder: "Saisissez une note pour cette commande" %>
      </div>
    </section>

    <%# ---- RAPPELS CLIENT (décoratifs / TODO : pas de colonnes en base) ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Rappels client</h2>
      <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" role="switch" id="reminderEmail">
        <label class="form-check-label" for="reminderEmail">Envoyer une confirmation de commande par e-mail</label>
      </div>
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="reminderSms">
        <label class="form-check-label" for="reminderSms">Envoyer un rappel SMS pour la re-collecte de la commande</label>
      </div>
    </section>

    <%# ---- CGV (décoratif / TODO) ---- %>
    <section class="order-form__section">
      <h2 class="order-form__title">Conditions générales de vente</h2>
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="cgv" checked>
        <label class="form-check-label" for="cgv">Appliquer les conditions générales par défaut</label>
      </div>
    </section>

    <%# ---- BOUTONS BAS ---- %>
    <div class="order-form__footer">
      <%= link_to "Annuler", orders_path, class: "btn btn-outline-primary" %>
      <%= form.submit "Finaliser la commande", class: "btn btn-success" %>
    </div>
  </div>
<% end %>
