<div class="container py-4">
  <%= form_with model: @order, url: orders_path, method: :post, local: true,
        html: { class: "order-wizard", data: { controller: "order-wizard" } } do |form| %>

    <%# --- Champs cachés pilotés par le wizard --- %>
    <input type="hidden" name="order[client_mode]" value="passage" data-order-wizard-target="clientModeInput">
    <%= form.hidden_field :customer_id, data: { order_wizard_target: "customerIdInput" } %>
    <%= form.hidden_field :payment_method, data: { order_wizard_target: "methodInput" } %>
    <%= form.hidden_field :payment_status, data: { order_wizard_target: "statusInput" } %>
    <%= form.hidden_field :status %>
    <%= form.hidden_field :priority %>
    <div data-order-wizard-target="lines" class="d-none"></div>

    <div class="wizard">
      <%# ---- HEADER ---- %>
      <div class="wizhead">
        <div class="wizhead__title">
          <%= link_to orders_path, class: "wizhead__close", aria: { label: "Fermer" } do %><i class="fa-solid fa-xmark"></i><% end %>
          Créer une commande
        </div>
        <%= link_to "Annuler", orders_path, class: "btn btn-outline-primary" %>
      </div>

      <%# ---- STEPPER ---- %>
      <div class="stepper">
        <% [["Client","fa-user"],["Prestations","fa-tag"],["Paiement","fa-euro-sign"],["Informations","fa-clipboard"],["Reçu","fa-circle-check"]].each_with_index do |(label, _icon), i| %>
          <button type="button" class="stepper__item" data-order-wizard-target="stepperItem" data-index="<%= i %>" data-action="order-wizard#jump">
            <span class="stepper__dot"><%= i + 1 %></span>
            <span class="stepper__label"><%= label %></span>
          </button>
          <% if i < 4 %><span class="stepper__line" data-order-wizard-target="stepperLine"></span><% end %>
        <% end %>
      </div>

      <%# ============ STEP 1 — CLIENT ============ %>
      <section class="wizstep is-active" data-order-wizard-target="step">
        <div class="wizstep__head">
          <div class="wizstep__title">À qui est destinée cette commande&nbsp;?</div>
          <div class="wizstep__sub">Encaissez un client de passage en un clic, ou rattachez la commande à un client connu pour suivre son historique.</div>
        </div>

        <div class="clientopts">
          <% [["passage","fa-bolt","Client de passage","Vente rapide, sans fiche client. Sélectionné par défaut."],
              ["existing","fa-users","Client existant","Rattachez la commande à une fiche déjà enregistrée."],
              ["new","fa-plus","Nouveau client","Créez une fiche en quelques secondes."]].each do |mode, icon, title, desc| %>
            <button type="button" class="clientopt <%= "is-on" if mode == "passage" %>" data-mode="<%= mode %>" data-action="order-wizard#selectMode">
              <span class="clientopt__tick"><i class="fa-solid fa-check"></i></span>
              <span class="clientopt__ic"><i class="fa-solid <%= icon %>"></i></span>
              <span class="clientopt__title"><%= title %></span>
              <span class="clientopt__desc"><%= desc %></span>
            </button>
          <% end %>
        </div>

        <%# panneau "client existant" %>
        <div class="clientpick d-none" data-order-wizard-target="clientPanel" data-mode="existing">
          <div class="customer-search">
            <div class="customer-search__field">
              <i class="fa-solid fa-magnifying-glass customer-search__icon"></i>
              <input type="text" class="form-control" placeholder="Rechercher un client par nom, e-mail ou téléphone"
                     autocomplete="off" data-order-wizard-target="clientSearch" data-action="input->order-wizard#filterClients">
            </div>
          </div>
          <div class="clientpick__list">
            <% @customers.each do |c| %>
              <button type="button" class="clientrow" data-order-wizard-target="clientRow"
                      data-id="<%= c.id %>" data-name="<%= c.display_name %>"
                      data-search="<%= [c.display_name, c.email, c.phone].compact.join(' ').downcase %>"
                      data-action="order-wizard#selectClient">
                <span class="app-avatar" style="width:34px;height:34px"><%= c.initials %></span>
                <span style="min-width:0">
                  <span class="clientrow__name"><%= c.display_name %></span>
                  <span class="clientrow__meta"><%= c.orders.count %> commandes · <%= c.phone.presence || "—" %></span>
                </span>
              </button>
            <% end %>
            <div class="muted d-none" data-order-wizard-target="clientEmpty" style="padding:14px 4px;grid-column:1/-1;color:var(--w-muted)">Aucun client ne correspond.</div>
          </div>
        </div>

        <%# panneau "nouveau client" %>
        <div class="clientpick d-none" data-order-wizard-target="clientPanel" data-mode="new" style="max-width:720px">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Nom complet</label>
              <input class="form-control" name="order[new_name]" placeholder="Prénom Nom" data-action="input->order-wizard#render">
            </div>
            <div class="col-md-6">
              <label class="form-label">Téléphone <span class="text-subtext">(facultatif)</span></label>
              <input class="form-control" name="order[new_phone]" placeholder="06 12 34 56 78">
            </div>
            <div class="col-md-6">
              <label class="form-label">E-mail <span class="text-subtext">(facultatif)</span></label>
              <input class="form-control" name="order[new_email]" placeholder="client@mail.fr">
            </div>
          </div>
        </div>
      </section>

      <%# ============ STEP 2 — PRESTATIONS & PANIER ============ %>
      <section class="wizstep" data-order-wizard-target="step">
        <div class="wizstep__head">
          <div class="wizstep__title">Ajoutez les prestations</div>
          <div class="wizstep__sub">Cliquez sur une prestation pour l'ajouter au panier.</div>
        </div>

        <div class="pos">
          <div>
            <div class="posgrid">
              <% @items.each do |item| %>
                <button type="button" class="postile" data-order-wizard-target="tile"
                        data-item-id="<%= item.id %>" data-price-ht="<%= item.price_ht %>"
                        data-name="<%= item.name %>" data-thumb="<%= item.photo_url %>"
                        data-action="order-wizard#addItem">
                  <% if item.photo_url.present? %><img class="postile__thumb" src="<%= item.photo_url %>" alt=""><% else %><span class="postile__thumb"></span><% end %>
                  <div style="flex:1;min-width:0">
                    <div class="postile__name"><%= item.name %></div>
                    <div class="postile__cat"><%= item.repair_bonus? ? "Éligible Bonus Réparation" : "Prestation" %></div>
                  </div>
                  <div class="postile__price"><%= number_to_currency(item.price_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
                </button>
              <% end %>
            </div>
          </div>

          <aside class="ticket">
            <div class="ticket__head">
              <span class="ticket__title">Panier</span>
              <button type="button" class="ticket__clear d-none" data-order-wizard-target="ticketClear" data-action="order-wizard#clearCart">Vider</button>
            </div>
            <div class="ticket__lines" data-order-wizard-target="ticketLines"></div>
            <div class="ticket__empty" data-order-wizard-target="ticketEmpty">
              <i class="fa-solid fa-cart-shopping"></i>
              <span>Ajoutez des prestations pour composer la commande.</span>
            </div>

            <%# Bonus Réparation — décoratif (TODO : pas de logique de déduction en base) %>
            <div class="bonuscard">
              <span class="bonuscard__ic"><i class="fa-solid fa-rotate"></i></span>
              <div class="bonuscard__txt">
                <div class="bonuscard__title">Bonus Réparation</div>
                <div class="bonuscard__desc">Aide de l'État (Refashion) appliquée automatiquement.</div>
              </div>
              <button type="button" class="w-toggle is-on" data-action="order-wizard#toggleSwitch" aria-label="Bonus réparation"></button>
            </div>

            <div class="ticket__totals">
              <div class="kv"><span class="kv__k">Sous-total HT</span><span class="kv__v" data-order-wizard-target="subtotal">0,00 €</span></div>
              <div class="kv"><span class="kv__k">TVA 20 %</span><span class="kv__v" data-order-wizard-target="vat">0,00 €</span></div>
              <div class="kv kv--total"><span class="kv__k">Total à payer</span><span class="kv__v" data-order-wizard-target="total">0,00 €</span></div>
            </div>

            <%# Réduction — décoratif (TODO : pas de colonne) %>
            <button type="button" class="btn btn-outline-primary btn-sm w-100 mt-3" data-action="order-wizard#toggleSwitch">+ Appliquer une réduction</button>
          </aside>
        </div>
      </section>

      <%# ============ STEP 3 — PAIEMENT ============ %>
      <section class="wizstep" data-order-wizard-target="step">
        <div class="wizstep__head">
          <div class="wizstep__title">Paiement</div>
          <div class="wizstep__sub">Sélectionnez le moyen et le statut du paiement.</div>
        </div>

        <h3 class="section-title" style="font-size:1rem;margin-bottom:14px">Moyen de paiement</h3>
        <div class="paygrid">
          <% [["Espèces","fa-money-bill-wave"],["Carte","fa-credit-card"],["Chèque","fa-money-check"]].each do |label, icon| %>
            <button type="button" class="paytile" data-value="<%= label %>" data-action="order-wizard#selectMethod">
              <span class="paytile__tick"><i class="fa-solid fa-check"></i></span>
              <span class="paytile__ic"><i class="fa-solid <%= icon %>"></i></span>
              <span class="paytile__label"><%= label %></span>
            </button>
          <% end %>
        </div>

        <h3 class="section-title" style="font-size:1rem;margin:30px 0 14px">Statut du paiement</h3>
        <div class="statusgrid">
          <button type="button" class="statustile is-paye" data-value="paid" data-action="order-wizard#selectStatus">
            <span class="statustile__ic"><i class="fa-solid fa-check"></i></span>
            <span>
              <span class="statustile__title">Payé maintenant</span>
              <span class="statustile__desc">Réglé à la création de la commande</span>
            </span>
          </button>
          <button type="button" class="statustile is-retrait" data-value="unpaid" data-action="order-wizard#selectStatus">
            <span class="statustile__ic"><i class="fa-solid fa-clock"></i></span>
            <span>
              <span class="statustile__title">À régler au retrait</span>
              <span class="statustile__desc">Le client paiera en venant chercher sa commande</span>
            </span>
          </button>
        </div>
      </section>

      <%# ============ STEP 4 — INFORMATIONS ============ %>
      <section class="wizstep" data-order-wizard-target="step">
        <div class="wizstep__head">
          <div class="wizstep__title">Informations de commande</div>
          <div class="wizstep__sub">Échéance de retrait, note interne et rappels au client.</div>
        </div>

        <div style="max-width:720px">
          <div class="mb-4">
            <label class="form-label">Date d'échéance (retrait)</label>
            <%= form.date_field :due_date, class: "form-control", style: "max-width:320px" %>
          </div>
          <div class="mb-2">
            <label class="form-label">Commentaire <span class="text-subtext">(facultatif)</span></label>
            <%= form.text_area :internal_notes, rows: 4, class: "form-control",
                  placeholder: "Note pour cette commande (état de la pièce, demande particulière…)" %>
          </div>

          <hr class="my-4">

          <%# Rappel SMS + CGV — décoratifs (TODO : pas de colonnes) %>
          <div class="inforow">
            <div class="inforow__txt">
              <div class="inforow__title">Rappel SMS au client</div>
              <div class="inforow__desc">Envoie automatiquement un SMS au client lorsque sa commande est prête.</div>
            </div>
            <button type="button" class="w-toggle" data-action="order-wizard#toggleSwitch" aria-label="Rappel SMS"></button>
          </div>
          <div class="inforow">
            <div class="inforow__txt">
              <div class="inforow__title">Conditions générales de vente</div>
              <div class="inforow__desc">Applique les CGV par défaut de l'atelier à cette commande.</div>
            </div>
            <button type="button" class="w-toggle is-on" data-action="order-wizard#toggleSwitch" aria-label="CGV"></button>
          </div>
        </div>
      </section>

      <%# ============ STEP 5 — RÉCAPITULATIF / REÇU ============ %>
      <section class="wizstep" data-order-wizard-target="step">
        <div class="wizstep__head">
          <div class="wizstep__title">Récapitulatif de la commande</div>
          <div class="wizstep__sub">Vérifiez les informations, générez le ticket de caisse puis validez pour créer la commande.</div>
        </div>

        <div class="recapwrap">
          <div class="recap__col">
            <div class="panel">
              <div class="d-flex align-items-center gap-3">
                <span class="app-avatar"><i class="fa-solid fa-user"></i></span>
                <div>
                  <div style="font-family:var(--font-heading);font-weight:700;font-size:1rem" data-order-wizard-target="clientName">Client de passage</div>
                  <div class="text-subtext" style="font-size:.85rem">Récapitulatif</div>
                </div>
                <div class="recap__chips ms-auto">
                  <span class="badge bg-secondary">Paiement : <span data-order-wizard-target="methodLabel">—</span></span>
                  <span class="badge bg-primary"><span data-order-wizard-target="statusLabel">—</span></span>
                </div>
              </div>
            </div>

            <div class="panel">
              <h3 class="section-title mb-2" style="font-size:1rem">Prestations</h3>
              <div data-order-wizard-target="recapLines"></div>
              <div class="mt-3">
                <div class="kv"><span class="kv__k">Sous-total HT</span><span class="kv__v" data-order-wizard-target="subtotal">0,00 €</span></div>
                <div class="kv"><span class="kv__k">TVA 20 %</span><span class="kv__v" data-order-wizard-target="vat">0,00 €</span></div>
                <div class="kv kv--total"><span class="kv__k">Total à payer</span><span class="kv__v" data-order-wizard-target="total">0,00 €</span></div>
              </div>
            </div>

            <%# Confirmation e-mail — décoratif %>
            <div class="confirmcard">
              <div class="confirmcard__top">
                <span class="confirmcard__ic"><i class="fa-solid fa-envelope"></i></span>
                <div>
                  <div class="confirmcard__title">Confirmation par e-mail</div>
                  <div class="confirmcard__desc">Envoyer la confirmation de commande au client.</div>
                </div>
                <button type="button" class="w-toggle ms-auto" data-action="order-wizard#toggleSwitch" aria-label="Confirmation e-mail"></button>
              </div>
            </div>
          </div>

          <%# Ticket de caisse %>
          <div class="ticketprint">
            <div class="genticket" data-order-wizard-target="receiptSlot">
              <span class="genticket__ic"><i class="fa-solid fa-clipboard"></i></span>
              <div>
                <div style="font-family:var(--font-heading);font-weight:700;font-size:1rem;color:var(--w-ink)">Ticket de caisse</div>
                <div class="text-subtext" style="font-size:.85rem;margin-top:4px">Générez un aperçu du ticket avant de l'imprimer.</div>
              </div>
              <button type="button" class="btn btn-primary" data-action="order-wizard#generateReceipt"><i class="fa-solid fa-clipboard me-2"></i>Générer le ticket</button>
            </div>

            <div class="d-none" data-order-wizard-target="receiptBox">
              <div class="receipt">
                <div class="receipt__center">
                  <div class="receipt__brand"><%= current_establishment&.name || "Popwear Pro" %></div>
                  <div class="receipt__addr"><%= current_establishment&.address %></div>
                </div>
                <hr class="receipt__rule">
                <div class="receipt__meta"><span>Client</span><span data-order-wizard-target="clientName">Client de passage</span></div>
                <hr class="receipt__rule">
                <div data-order-wizard-target="receiptLines"></div>
                <hr class="receipt__rule">
                <div class="receipt__row"><span>Sous-total HT</span><span data-order-wizard-target="subtotal">0,00 €</span></div>
                <div class="receipt__row"><span>TVA 20 %</span><span data-order-wizard-target="vat">0,00 €</span></div>
                <hr class="receipt__rule">
                <div class="receipt__row receipt__tot"><span>TOTAL</span><span data-order-wizard-target="total">0,00 €</span></div>
                <div class="receipt__row"><span>Paiement</span><span data-order-wizard-target="methodLabel">—</span></div>
                <div class="receipt__row"><span>Statut</span><span data-order-wizard-target="statusLabel">—</span></div>
                <hr class="receipt__rule">
                <div class="receipt__foot">Merci de votre visite — à bientôt à l'atelier&nbsp;!</div>
                <div class="receipt__barcode"></div>
              </div>
              <div class="printactions">
                <button type="button" class="btn btn-outline-primary btn-sm" data-action="order-wizard#print"><i class="fa-solid fa-print me-1"></i>Imprimer</button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <%# ---- NAV ---- %>
      <div class="wiznav">
        <button type="button" class="btn btn-light" data-order-wizard-target="back" data-action="order-wizard#back"><i class="fa-solid fa-chevron-left me-1"></i>Retour</button>
        <div class="d-flex align-items-center gap-3">
          <span class="wiznav__hint d-none" data-order-wizard-target="hint"></span>
          <button type="button" class="btn btn-primary" data-order-wizard-target="next" data-action="order-wizard#next">
            Continuer<span data-amount></span><i class="fa-solid fa-arrow-right ms-1"></i>
          </button>
          <%= form.submit "Valider la commande", class: "btn btn-success d-none", data: { order_wizard_target: "finalize" } %>
        </div>
      </div>
    </div>
  <% end %>
</div>
