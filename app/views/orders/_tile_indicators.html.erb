<%# Indicateurs de la tuile kanban : badge rappel SMS (J+3/J+10) + horloge d'urgence.
    local: order. Re-rendu en Turbo Stream → se vide quand l'action est résolue. %>
<div id="tile_indicators_<%= order.id %>" class="d-flex align-items-center gap-1 flex-shrink-0">
  <%# Badge rappel SMS à envoyer (J+3 / J+10), icône "envoi" %>
  <% if (level = order.pickup_reminder_level) %>
    <span class="badge rounded-pill bg-danger d-inline-flex align-items-center gap-1"
          title="SMS de rappel à envoyer — en attente de retrait depuis J+<%= level %> ouvrés">
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 16 16">
        <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z"/>
      </svg>
      J+<%= level %>
    </span>
  <% end %>
  <%# Horloge d'urgence : fond plein jaune (imminent) / rouge (dépassé) %>
  <% if order.urgent? %>
    <% overdue = order.days_until_due&.negative? %>
    <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
          style="width: 28px; height: 28px; background: <%= overdue ? "#DC3545" : "#F4AD22" %>;"
          title="<%= overdue ? "Date de retrait dépassée" : "Date de retrait imminente" %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#fff" viewBox="0 0 16 16">
        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
      </svg>
    </span>
  <% end %>
</div>
