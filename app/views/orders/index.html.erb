<div class="orders-kanban" data-controller="kanban order-panel" data-open-order="<%= params[:open].to_i if params[:open].present? %>">

  <div>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Commandes</h1>
      <%= link_to new_order_path, class: "app-sidebar__cta", style: "width: auto; padding: 0 1.25rem;" do %>
        <i class="fa-solid fa-plus"></i>
        <span>Nouvelle commande</span>
      <% end %>
    </div>

    <div data-controller="search">
      <%= form_with url: orders_path, method: :get, data: { search_target: "form", turbo_frame: "orders-kanban-board" }, class: "mb-4" do |f| %>
        <div class="input-group" style="max-width: 380px;">
          <span class="input-group-text bg-white border-end-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
            </svg>
          </span>
          <%= f.text_field :q,
              value: @search_query,
              placeholder: "Rechercher un client ou N° de commande…",
              class: "form-control border-start-0 ps-0 bg-white",
              autocomplete: "off",
              data: { action: "input->search#submit" } %>
        </div>
      <% end %>
    </div>

    <turbo-frame id="orders-kanban-board" data-turbo-action="replace">
    <div class="d-flex gap-3 align-items-start overflow-auto">
      <% @columns.each do |column| %>
        <div class="kanban-column flex-shrink-0 bg-white rounded-3 p-3"
             style="width: 280px;"
             data-status="<%= column[:target_status] %>"
             data-action="dragover->kanban#dragover dragleave->kanban#dragleave drop->kanban#drop">
          <% badge_styles = { "new" => "bg-gradient-green", "in_progress" => "bg-gradient-orange", "recollect" => "bg-warning", "done" => nil } %>
          <div class="d-flex align-items-center mb-3">
            <h6 class="mb-0 fw-semibold"><%= column[:label] %></h6>
            <% if badge_styles[column[:key]] %>
              <span class="badge rounded-pill text-white ms-auto <%= badge_styles[column[:key]] %>"><%= column[:orders].count %></span>
            <% else %>
              <span class="badge rounded-pill text-white ms-auto" style="background: #411221;"><%= column[:orders].count %></span>
            <% end %>
          </div>

          <% column[:orders].each do |order| %>
            <div class="card mb-3 border-0 bg-white"
                 draggable="true"
                 data-order-id="<%= order.id %>"
                 data-phone="<%= order.customer.phone %>"
                 data-customer-name="<%= [order.customer.firstname, order.customer.lastname].compact.join(' ').presence || 'Client' %>"
                 data-status="<%= order.status %>"
                 data-payment-status="<%= order.payment_status %>"
                 data-action="dragstart->kanban#dragstart dragend->kanban#dragend"
                 style="box-shadow: 0 4px 16px rgba(19,21,35,.06); cursor: grab;">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-1">
                  <strong class="text-primary">
                    <% if order.customer.firstname %>
                      <%= order.customer.firstname&.first %>. <%= order.customer.lastname %>
                    <% else %>
                      <em>Anonyme</em>
                    <% end %>
                  </strong>
                  <% if order.urgent? %>
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-25" style="width: 28px; height: 28px;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#F4AD22" viewBox="0 0 16 16">
                        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                      </svg>
                    </span>
                  <% end %>
                </div>

                <small class="text-muted d-block mb-2" style="font-size: 0.75rem;">N° CMD-<%= order.id %></small>

                <% if order.due_date.present? %>
                  <small class="text-muted d-block mb-1">Retrait : <%= order.due_date.strftime("%d/%m/%y") %></small>
                <% end %>

                <% if order.order_lines.any? %>
                  <p class="mb-1"><small class="fw-semibold text-muted">Prestations</small></p>
                  <% order.order_lines.each do |line| %>
                    <p class="mb-0"><small class="text-muted"><%= line.item.name %></small></p>
                  <% end %>
                <% end %>

                <div class="mt-2 pt-2 border-top" style="border-color: #EAE4DF !important;">
                  <small class="text-muted">
                    <%= number_to_currency(order.total_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> HT
                  </small>
                  <div class="fw-bold text-secondary">
                    <%= number_to_currency(order.total_ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> TTC
                  </div>
                </div>

                <div class="mt-3">
                  <a href="<%= order_path(order) %>"
                     class="btn btn-outline-primary btn-sm w-100"
                     data-turbo-frame="order-detail"
                     data-action="click->order-panel#open">Voir le détail</a>
                </div>
              </div>
            </div>
          <% end %>

          <% if column[:orders].empty? %>
            <p class="text-muted text-center small mt-2">Aucune commande</p>
          <% end %>

          <% if column[:key] == "done" && @archived_count > 0 %>
            <div class="text-center mt-3 pt-2 border-top" style="border-color: #EAE4DF !important;">
              <%= link_to archives_orders_path, class: "text-muted small text-decoration-none", data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                  <path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 1 12.5V5a1 1 0 0 1-1-1V2zm2 3v7.5A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5H2zm13-3H1v2h14V2zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                </svg>
                Voir les <%= @archived_count %> commandes archivées
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    </turbo-frame>
  </div>

  <aside class="order-panel" data-order-panel-target="panel" aria-hidden="true">
    <div class="order-panel-body">
      <turbo-frame id="order-detail">
        <p class="text-muted text-center py-2">Sélectionnez une commande.</p>
      </turbo-frame>
    </div>
  </aside>

</div>
