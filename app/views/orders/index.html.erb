<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Commandes</h1>
  <%= link_to "+ Créer une commande", new_order_path, class: "btn btn-primary" %>
</div>

<div class="d-flex gap-3 align-items-start overflow-auto">
    <% @columns.each do |column| %>
      <div class="kanban-column flex-shrink-0 bg-white rounded-3 p-3" style="width: 280px;">
        <% badge_styles = { "new" => "bg-gradient-green", "in_progress" => "bg-gradient-orange", "recollect" => "bg-warning", "done" => nil } %>
        <div class="d-flex align-items-center mb-3">
          <h6 class="mb-0 fw-semibold"><%= column[:label] %></h6>
          <% if badge_styles[column[:key]] %>
            <span class="badge rounded-pill text-white ms-auto <%= badge_styles[column[:key]] %>"><%= column[:orders].count %></span>
          <% else %>
            <span class="badge rounded-pill text-white ms-auto" style="background: #411221;"><%= column[:orders].count %></span>
          <% end %>
        </div>

        <% column[:orders].each do |order| %>
          <div class="card mb-3 border-0 bg-white" style="box-shadow: 0 4px 16px rgba(19,21,35,.06);">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-1">
                <strong class="text-primary">
                  <%= order.customer.firstname %> <%= order.customer.lastname.first %>.
                </strong>
                <% if order.urgent? %>
                  <span class="badge rounded-pill bg-warning text-white" style="font-size: .7rem;">Urgent</span>
                <% end %>
              </div>

              <small class="text-muted d-block mb-1">
                <%= l(order.created_at.to_date, format: :short) %>
              </small>

              <small class="text-muted d-block mb-2">
                N° commande : VDY<%= order.id.to_s.rjust(6, "0") %>
              </small>

              <% if order.order_lines.any? %>
                <p class="mb-1"><small class="fw-semibold text-muted">Prestations</small></p>
                <% order.order_lines.each do |line| %>
                  <p class="mb-0"><small class="text-muted"><%= line.item.name %></small></p>
                <% end %>
              <% end %>

              <div class="mt-2 pt-2 border-top" style="border-color: #EAE4DF !important;">
                <small class="text-muted">
                  <%= number_to_currency(order.total_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> HT
                </small>
                <div class="fw-bold text-secondary">
                  <%= number_to_currency(order.total_ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> TTC
                </div>
              </div>

              <div class="mt-3">
                <%= link_to "Voir le détail", order_path(order), class: "btn btn-outline-primary btn-sm w-100" %>
              </div>
            </div>
          </div>
        <% end %>

        <% if column[:orders].empty? %>
          <p class="text-muted text-center small mt-2">Aucune commande</p>
        <% end %>
      </div>
    <% end %>
  </div>
