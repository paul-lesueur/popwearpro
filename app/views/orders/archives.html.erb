<div class="container-fluid px-4 py-4" style="max-width: 860px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-1">Commandes archivées</h1>
      <p class="text-muted small mb-0">
        Commandes terminées depuis plus de <%= Order::ARCHIVE_THRESHOLD_DAYS %> jours.
      </p>
    </div>
    <%= link_to "← Retour au kanban", orders_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <% if @archived_orders.empty? %>
    <p class="text-muted text-center py-5">Aucune commande archivée.</p>
  <% else %>
    <div class="d-flex flex-column gap-3">
      <% @archived_orders.each do |order| %>
        <div class="card border-0 bg-white" style="box-shadow: 0 4px 16px rgba(19,21,35,.06);">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <strong class="text-primary">
                  <% if order.customer %>
                    <%= order.customer.firstname&.first %>. <%= order.customer.lastname %>
                  <% else %>
                    <em>Anonyme</em>
                  <% end %>
                </strong>
                <small class="text-muted d-block mt-1">
                  N° CMD-<%= order.id %> &middot; archivée le <%= order.archived_at.strftime("%d/%m/%Y") %>
                </small>

                <% if order.order_lines.any? %>
                  <p class="mb-0 mt-2">
                    <% order.order_lines.each do |line| %>
                      <small class="text-muted"><%= line.item.name %></small><br>
                    <% end %>
                  </p>
                <% end %>
              </div>

              <div class="d-flex flex-column align-items-end gap-2">
                <div class="text-end">
                  <small class="text-muted">
                    <%= number_to_currency(order.total_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> HT
                  </small>
                  <div class="fw-bold text-secondary">
                    <%= number_to_currency(order.total_ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %> TTC
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
