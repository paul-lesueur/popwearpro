<header class="app-header">
  <%# Logo : fait partie de la navbar horizontale (aligné au-dessus de la sidebar). %>
  <%= link_to root_path, class: "app-header__brand" do %>
    <%= image_tag "logo-popwear-pro.png", alt: "Popwear Pro", class: "app-header__brand-logo" %>
  <% end %>

  <%# Hamburger : ouvre la sidebar en off-canvas sous 992px uniquement. %>
  <button class="app-header__burger d-lg-none" type="button"
          data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
          aria-controls="sidebarOffcanvas" aria-label="Ouvrir le menu">
    <i class="fa-solid fa-bars"></i>
  </button>

  <div class="dropdown ms-auto">
    <a href="#" class="app-header__user dropdown-toggle" id="userMenu"
       data-bs-toggle="dropdown" aria-expanded="false">
      <span class="app-avatar">
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "app-avatar__image" %>
        <% else %>
          <%= user_initials(current_user) %>
        <% end %>
      </span>

      <span class="app-header__name d-none d-sm-inline">
        <%= current_user.name.presence || current_user.email %>
      </span>

      <i class="fa-solid fa-chevron-down app-header__chevron"></i>
    </a>

    <ul class="dropdown-menu dropdown-menu-end app-header__menu" aria-labelledby="userMenu">
      <li>
        <%= link_to profile_path, class: "dropdown-item app-header__menu-item" do %>
          <i class="fa-solid fa-user"></i>
          <span>Mon profil</span>
        <% end %>
      </li>

      <li><hr class="dropdown-divider app-header__divider"></li>

      <li>
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item app-header__menu-item app-header__menu-item--danger" do %>
          <i class="fa-solid fa-right-from-bracket"></i>
          <span>Déconnexion</span>
        <% end %>
      </li>
    </ul>
  </div>
</header>
