<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Popwearpro" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Popwearpro">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Polices du Design System : Inter (corps) + League Spartan (titres) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=League+Spartan:wght@700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= asset_path('favicon-popwear-transparent.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon-popwear-transparent.png') %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="app-shell">
        <%= render "shared/sidebar" %>
        <%= render "shared/sidebar_offcanvas" %>

        <div class="app-main">
          <%= render "shared/header" %>
          <%= render "shared/flashes" %>

          <main class="app-content">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <%# Pages publiques (Devise) : pas de chrome applicatif. %>
      <%= render "shared/flashes" %>
      <main class="auth-content">
        <%= yield %>
      </main>
    <% end %>
    <div id="payment-toast-container" class="sms-toast-container" data-turbo-permanent></div>
  </body>
</html>
