<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Popwear Pro — Gestion d’atelier pour artisans" %></title>

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Popwear Pro aide les artisans à gérer leurs commandes, leurs clients, leurs ventes et leur atelier au quotidien." %>">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Popwear Pro">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Open Graph %>
    <meta property="og:title" content="<%= content_for?(:og_title) ? yield(:og_title) : "Popwear Pro — Gestion d’atelier pour artisans" %>">
    <meta property="og:description" content="<%= content_for?(:og_description) ? yield(:og_description) : "Un outil simple pour gérer les commandes, clients, ventes et suivis d’atelier des artisans." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= "#{request.base_url}#{asset_path('og-popwear-pro.png')}" %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Aperçu de l’application Popwear Pro">

    <%# Twitter / X preview %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:og_title) ? yield(:og_title) : "Popwear Pro — Gestion d’atelier pour artisans" %>">
    <meta name="twitter:description" content="<%= content_for?(:og_description) ? yield(:og_description) : "Un outil simple pour gérer les commandes, clients, ventes et suivis d’atelier des artisans." %>">
    <meta name="twitter:image" content="<%= "#{request.base_url}#{asset_path('og-popwear-pro.png')}" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Polices du Design System : Inter (corps) + League Spartan (titres) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=League+Spartan:wght@500;600;700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= asset_path('favicon-popwear-transparent.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon-popwear-transparent.png') %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="app-shell">
        <%# Navbar horizontale pleine largeur : logo (gauche) + menu utilisateur (droite). %>
        <%= render "shared/header" %>

        <div class="app-body">
          <%= render "shared/sidebar" %>
          <%= render "shared/sidebar_offcanvas" %>

          <div class="app-main">
            <%= render "shared/flashes" %>

            <main class="app-content">
              <%= yield %>
            </main>
          </div>
        </div>
      </div>
    <% else %>
      <%# Pages publiques (Devise) : pas de chrome applicatif. %>
      <%= render "shared/flashes" %>
      <main class="auth-content">
        <%= yield %>
      </main>
    <% end %>

    <div id="payment-toast-container" class="sms-toast-container" data-turbo-permanent></div>
  </body>
</html>
