<div class="page-wrapper catalogue-detail-page pb-4">
  <div class="catalogue-detail-header">
    <div>
      <%= link_to items_path, class: "catalogue-back-link" do %>
        <i class="fa-solid fa-arrow-left"></i>
        Retour au catalogue
      <% end %>

      <div class="catalogue-detail-title-row">
        <span class="catalogue-detail-icon">
          <%= catalog_icon(@item.icon) %>
        </span>

        <div>
          <h1><%= @item.name %></h1>
          <p>Détail de l’élément catalogue</p>
        </div>
      </div>
    </div>

    <div class="catalogue-detail-actions">
      <%= link_to edit_item_path(@item), class: "catalogue-btn catalogue-btn-outline" do %>
        <i class="fa-solid fa-pen"></i>
        Modifier
      <% end %>

      <%= link_to items_path, class: "catalogue-btn catalogue-btn-dark" do %>
        Retour
      <% end %>
    </div>
  </div>

  <% price_ht = @item.price_ht.to_f %>
  <% vat_rate = @item.vat_rate.to_f %>
  <% price_ttc = price_ht * (1 + vat_rate / 100) %>

  <div class="catalogue-detail-grid">
    <section class="catalogue-detail-card catalogue-detail-main">
      <% if @item.photo_url.present? %>
        <%= image_tag @item.photo_url, class: "catalogue-detail-image" %>
      <% else %>
        <div class="catalogue-detail-placeholder">
          <span class="catalogue-detail-placeholder-icon">
            <%= catalog_icon(@item.icon) %>
          </span>

          <div>
            <strong><%= @item.name %></strong>
            <p>Élément du catalogue</p>
          </div>
        </div>
      <% end %>

      <div class="catalogue-detail-content">
        <div class="catalogue-detail-section-title">
          Informations principales
        </div>

        <div class="catalogue-detail-info-list">
          <div class="catalogue-detail-info">
            <span>Prix HT</span>
            <strong>
              <%= number_to_currency(@item.price_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
            </strong>
          </div>

          <div class="catalogue-detail-info">
            <span>TVA</span>
            <strong><%= @item.vat_rate %> %</strong>
          </div>

          <div class="catalogue-detail-info">
            <span>Prix TTC estimé</span>
            <strong>
              <%= number_to_currency(price_ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
            </strong>
          </div>
        </div>
      </div>
    </section>

    <aside class="catalogue-detail-card catalogue-detail-side">
      <div class="catalogue-detail-section-title">
        Statut catalogue
      </div>

      <div class="catalogue-status-list">
        <div class="catalogue-status-row">
          <span>Disponibilité</span>

          <% if @item.active? %>
            <strong class="catalogue-status-badge is-active">Actif</strong>
          <% else %>
            <strong class="catalogue-status-badge is-inactive">Inactif</strong>
          <% end %>
        </div>

        <div class="catalogue-status-row">
          <span>Bonus réparation</span>

          <% if @item.repair_bonus? %>
            <strong class="catalogue-status-badge is-bonus">Éligible</strong>
          <% else %>
            <strong class="catalogue-status-badge is-neutral">Non éligible</strong>
          <% end %>
        </div>
      </div>

      <div class="catalogue-detail-note">
        <i class="fa-solid fa-circle-info"></i>
        <p>
          Cet élément peut être utilisé dans les commandes et les encaissements selon son statut.
        </p>
      </div>
    </aside>
  </div>
</div>
