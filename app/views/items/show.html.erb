<div class="page-wrapper pb-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1><%= @item.name %></h1>
      <p class="text-muted">Détail de l'élément catalogue</p>
    </div>

    <div>
      <%= link_to edit_item_path(@item), class: "btn btn-primary" do %>
        <i class="fa-solid fa-pencil me-2"></i>Modifier
      <% end %>
      <%= link_to items_path, class: "btn btn-outline-primary" do %>
        <i class="fa-solid fa-arrow-left me-2"></i>Retour
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <% if @item.photo_url.present? %>
      <%= image_tag @item.photo_url, class: "card-img-top", style: "height: 280px; object-fit: cover;" %>
    <% end %>

    <div class="card-body">
      <p>
        <strong>Prix HT :</strong>
        <%= number_to_currency(@item.price_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
      </p>

      <p>
        <strong>TVA :</strong>
        <%= @item.vat_rate %> %
      </p>

      <p>
        <strong>Bonus réparation :</strong>
        <%= @item.repair_bonus? ? "Oui" : "Non" %>
      </p>

      <p>
        <strong>Statut :</strong>
        <%= @item.active? ? "Actif" : "Inactif" %>
      </p>
    </div>
  </div>
</div>
