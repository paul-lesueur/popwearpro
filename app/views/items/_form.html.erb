<%= form_with model: item, local: true do |form| %>
  <% if item.errors.any? %>
    <div class="alert alert-danger">
      <p><strong>Erreur :</strong></p>
      <ul>
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :category, "Catégorie", class: "form-label" %>
    <%= form.select :category,
      [["Prestation", "service"], ["Produit", "product"]],
      {},
      class: "form-select"
    %>
  </div>

  <div class="mb-3">
    <%= form.label :name, "Nom", class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Ex : Ourlet pantalon" %>
  </div>

  <div class="mb-3">
    <%= form.label :price_ht, "Prix HT", class: "form-label" %>
    <%= form.number_field :price_ht, step: 0.01, class: "form-control", placeholder: "Ex : 18.00" %>
  </div>

  <div class="mb-3">
    <%= form.label :vat_rate, "TVA (%)", class: "form-label" %>
    <%= form.number_field :vat_rate, step: 0.01, class: "form-control", placeholder: "Ex : 20.00" %>
  </div>

  <div class="mb-3">
    <%= form.label :photo_url, "URL de l'image", class: "form-label" %>
    <%= form.text_field :photo_url, class: "form-control", placeholder: "https://..." %>
  </div>

  <div class="form-check mb-3">
    <%= form.check_box :repair_bonus, class: "form-check-input" %>
    <%= form.label :repair_bonus, "Éligible bonus réparation", class: "form-check-label" %>
  </div>

  <div class="form-check mb-4">
    <%= form.check_box :active, class: "form-check-input" %>
    <%= form.label :active, "Actif dans le catalogue", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit "Enregistrer", class: "btn btn-primary" %>
    <%= link_to "Annuler", items_path, class: "btn btn-secondary" %>
  </div>
<% end %>
