<div class="sales-page">
  <div class="sales-header">
    <div>
      <h1>Ventes</h1>

      <div class="sales-tabs">
        <%= link_to "Tableau de bord", sales_path, class: "sales-tab" %>
        <%= link_to "Transactions", sales_transactions_path, class: "sales-tab" %>
        <%= link_to "Prestations et Produits", items_path, class: "sales-tab is-active" %>
      </div>
    </div>
  </div>

  <div class="container py-4 px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1>Catalogue</h1>
        <p class="text-muted">Gérez vos prestations facturables.</p>
      </div>

      <%= link_to "Nouvel élément", new_item_path, class: "btn btn-primary" %>
    </div>

    <div class="row">
      <% @items.each do |item| %>
        <div class="col-md-4 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <div class="d-flex align-items-start gap-3 mb-2">
                <span class="catalog-icon-halo" style="width:48px;height:48px;">
                  <%= catalog_icon(item.icon) %>
                </span>

                <div class="d-flex justify-content-between align-items-start flex-grow-1">
                  <h5 class="card-title mb-0"><%= item.name %></h5>

                  <% if item.active? %>
                    <span class="badge bg-success">Actif</span>
                  <% else %>
                    <span class="badge bg-secondary">Inactif</span>
                  <% end %>
                </div>
              </div>

              <p class="mb-1">
                <strong>Prix HT :</strong>
                <%= number_to_currency(item.price_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
              </p>

              <p class="mb-1">
                <strong>TVA :</strong>
                <%= item.vat_rate %> %
              </p>

              <% if item.repair_bonus? %>
                <span class="badge bg-warning text-dark mb-3">Bonus réparation</span>
              <% end %>

              <div class="mt-3 d-flex gap-2">
                <%= link_to "Voir", item_path(item), class: "btn btn-outline-primary btn-sm" %>

                <%= link_to "Modifier", edit_item_path(item), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @items.empty? %>
      <div class="alert alert-info">
        Aucun élément dans le catalogue pour le moment.
      </div>
    <% end %>
  </div>
</div>
