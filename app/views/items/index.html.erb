<div class="sales-page catalogue-page">
  <div class="sales-header">
    <div>
      <h1>Catalogue</h1>
      <p class="text-muted">Gérez les prestations, articles et tarifs proposés par votre atelier.</p>

      <div class="sales-tabs">
        <%= link_to "Tableau de bord", sales_path, class: "sales-tab" %>
        <%= link_to "Transactions", sales_transactions_path, class: "sales-tab" %>
        <%= link_to "Catalogue", items_path, class: "sales-tab is-active" %>
      </div>
    </div>

    <%= link_to new_item_path, class: "btn-cta" do %>
      <i class="fa-solid fa-plus"></i>
      <span>Nouvel élément</span>
    <% end %>
  </div>

  <div class="container py-4 px-0">
    <% if @items.any? %>
      <div class="row">
        <% @items.each do |item| %>
          <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <div class="d-flex align-items-start gap-3 mb-2">
                  <span class="catalog-icon-halo" style="width:48px;height:48px;">
                    <%= catalog_icon(item.icon) %>
                  </span>

                  <div class="d-flex justify-content-between align-items-start flex-grow-1">
                    <h5 class="card-title mb-0"><%= item.name %></h5>

                    <% if item.active? %>
                      <span class="badge bg-success">Actif</span>
                    <% else %>
                      <span class="badge bg-secondary">Inactif</span>
                    <% end %>
                  </div>
                </div>

                <p class="mb-1">
                  <strong>Prix HT :</strong>
                  <%= number_to_currency(item.price_ht, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                </p>

                <p class="mb-1">
                  <strong>TVA :</strong>
                  <%= item.vat_rate %> %
                </p>

                <% if item.repair_bonus? %>
                  <span class="badge bg-warning text-dark mb-3">Bonus réparation</span>
                <% end %>

                <div class="mt-3 d-flex gap-2">
                  <%= link_to "Voir", item_path(item), class: "btn btn-outline-primary btn-sm" %>
                  <%= link_to "Modifier", edit_item_path(item), class: "btn btn-outline-secondary btn-sm" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="catalog-pagination" aria-label="Pagination du catalogue">
          <% if @page > 1 %>
            <%= link_to items_path(page: @page - 1), class: "catalog-pagination-arrow" do %>
              <i class="fa-solid fa-chevron-left"></i>
            <% end %>
          <% else %>
            <span class="catalog-pagination-arrow is-disabled">
              <i class="fa-solid fa-chevron-left"></i>
            </span>
          <% end %>

          <% (1..@total_pages).each do |page_number| %>
            <% if page_number == @page %>
              <span class="catalog-pagination-link is-active">
                <%= page_number %>
              </span>
            <% else %>
              <%= link_to page_number, items_path(page: page_number), class: "catalog-pagination-link" %>
            <% end %>
          <% end %>

          <% if @page < @total_pages %>
            <%= link_to items_path(page: @page + 1), class: "catalog-pagination-arrow" do %>
              <i class="fa-solid fa-chevron-right"></i>
            <% end %>
          <% else %>
            <span class="catalog-pagination-arrow is-disabled">
              <i class="fa-solid fa-chevron-right"></i>
            </span>
          <% end %>
        </nav>
      <% end %>
    <% else %>
      <div class="alert alert-info">
        Aucun élément dans le catalogue pour le moment.
      </div>
    <% end %>
  </div>
</div>
