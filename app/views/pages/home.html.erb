<div class="home-page landing-v2">

  <%# Navbar %>
  <nav class="lp-nav">
    <div class="lp-nav__left">
      <div class="lp-nav__brand">
        <%= image_tag "logo-popwear-pro.png", alt: "Popwear Pro", class: "lp-nav__logo" %>
      </div>

      <div class="lp-nav__links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#comment-ca-marche">Comment ça marche</a>
        <a href="#tarifs">Tarifs</a>
      </div>
    </div>

    <div class="lp-nav__actions">
      <% if user_signed_in? %>
        <%= link_to "Accéder à l'app", dashboard_path, class: "lp-btn lp-btn--primary lp-btn--sm" %>
        <%= link_to "Se déconnecter",
                    destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "lp-btn lp-btn--ghost lp-btn--sm" %>
      <% else %>
        <%= link_to "Se connecter", new_user_session_path, class: "lp-btn lp-btn--ghost lp-btn--sm" %>
        <%= link_to "Essayer Popwear Pro", new_user_registration_path, class: "lp-btn lp-btn--primary lp-btn--sm" %>
      <% end %>
    </div>
  </nav>

  <%# Hero %>
  <section class="lp-hero">
    <div class="lp-hero-shell">
      <div class="lp-hero-shell__glow lp-hero-shell__glow--left"></div>
      <div class="lp-hero-shell__glow lp-hero-shell__glow--right"></div>

      <div class="lp-hero__content">
        <p class="lp-eyebrow">
          <i class="fa-solid fa-briefcase"></i>
          Logiciel de gestion d’atelier
        </p>

        <h1 class="lp-hero__title">
          Le logiciel de <span>gestion d’atelier</span> pour artisans.
        </h1>

        <p class="lp-hero__subtitle">
          Popwear Pro centralise vos commandes, vos clients, vos prestations,
          vos paiements et vos rappels clients par SMS et email.
        </p>

        <p class="lp-hero__note">
          <i class="fa-solid fa-check"></i>
          Un outil simple pour suivre l’activité de l’atelier sans multiplier les fichiers, carnets et messages.
        </p>
      </div>

      <div class="lp-hero__visual">
        <div class="lp-hero-illustration">
          <%= image_tag "home-illustration.png", alt: "Illustration Popwear Pro", class: "lp-hero-image" %>
        </div>
      </div>
    </div>
  </section>

  <%# Fonctionnalités %>
  <section class="lp-section" id="fonctionnalites">
    <div class="lp-section__heading">
      <p class="lp-section__eyebrow">Fonctionnalités</p>
      <h2>Tout l’atelier au même endroit</h2>
      <p>
        Popwear Pro regroupe les éléments essentiels pour gérer une activité artisanale :
        commandes, clients, prestations, paiements et suivi client.
      </p>
    </div>

    <div class="lp-modules-grid">
      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-tag"></i>
        </div>
        <h3>Commandes atelier</h3>
        <p>
          Créez une commande, ajoutez des prestations ou articles,
          puis suivez son statut jusqu’à la remise au client.
        </p>
      </article>

      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-users"></i>
        </div>
        <h3>Clients</h3>
        <p>
          Gardez les coordonnées, les notes et l’historique des commandes
          de chaque client.
        </p>
      </article>

      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-list"></i>
        </div>
        <h3>Catalogue</h3>
        <p>
          Centralisez vos prestations et articles avec leurs prix,
          prêts à être ajoutés à une commande.
        </p>
      </article>

      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-euro-sign"></i>
        </div>
        <h3>Paiements</h3>
        <p>
          Suivez les paiements liés aux commandes et conservez
          l’historique des transactions clients.
        </p>
      </article>

      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-bell"></i>
        </div>
        <h3>Rappels clients</h3>
        <p>
          Prévenez vos clients par SMS ou email selon l’avancement
          de leur commande.
        </p>
      </article>

      <article class="lp-module-card">
        <div class="lp-icon">
          <i class="fa-solid fa-chart-simple"></i>
        </div>
        <h3>Tableau de bord</h3>
        <p>
          Visualisez les commandes en cours, les urgences, les paiements
          et l’activité récente.
        </p>
      </article>
    </div>
  </section>

  <%# Comment ça marche %>
  <section class="lp-section lp-workflow-section" id="comment-ca-marche">
    <div class="lp-section__heading">
      <p class="lp-section__eyebrow">Comment ça marche</p>
      <h2>Un parcours simple pour chaque commande</h2>
      <p>
        De la prise en charge à la remise au client, Popwear Pro suit
        les étapes clés du travail en atelier.
      </p>
    </div>

    <div class="lp-timeline">
      <div class="lp-timeline__line"></div>

      <article class="lp-timeline__step">
        <div class="lp-timeline__dot">1</div>
        <div class="lp-timeline__card">
          <h3>Créer la commande</h3>
          <p>
            Sélectionnez un client existant ou créez rapidement une commande
            pour un client de passage.
          </p>
        </div>
      </article>

      <article class="lp-timeline__step">
        <div class="lp-timeline__dot">2</div>
        <div class="lp-timeline__card">
          <h3>Ajouter les prestations</h3>
          <p>
            Ajoutez les prestations ou articles depuis le catalogue
            avec les prix déjà renseignés.
          </p>
        </div>
      </article>

      <article class="lp-timeline__step">
        <div class="lp-timeline__dot">3</div>
        <div class="lp-timeline__card">
          <h3>Suivre l’avancement</h3>
          <p>
            Faites avancer la commande dans l’atelier :
            nouvelle, en cours, prête ou terminée.
          </p>
        </div>
      </article>

      <article class="lp-timeline__step">
        <div class="lp-timeline__dot">4</div>
        <div class="lp-timeline__card">
          <h3>Encaisser et prévenir</h3>
          <p>
            Suivez le paiement puis prévenez le client par SMS ou email
            lorsque la commande évolue.
          </p>
        </div>
      </article>
    </div>
  </section>

  <%# Tarifs %>
  <section class="lp-section lp-pricing-section" id="tarifs">
    <div class="lp-section__heading">
      <p class="lp-section__eyebrow">Tarifs</p>
      <h2>Une offre pour chaque étape de votre atelier</h2>
      <p>
        Commencez gratuitement, puis activez les fonctionnalités utiles
        quand votre activité grandit.
      </p>
    </div>

    <div class="lp-pricing-grid">
      <article class="lp-plan">
        <h3>Plan Gratuit <span>· Découverte</span></h3>

        <div class="lp-plan__price">
          <strong>0€</strong>
          <small>/ mois</small>
        </div>

        <p>Pour tester Popwear Pro simplement.</p>

        <ul>
          <li>Fiche établissement</li>
          <li>Catalogue limité</li>
          <li>Création de commandes atelier</li>
          <li>Suivi des statuts</li>
          <li>Fichier client limité</li>
          <li>Tableau de bord de base</li>
        </ul>
      </article>

      <article class="lp-plan">
        <h3>Offre Basique</h3>

        <div class="lp-plan__price">
          <strong>15€</strong>
          <small>/ mois</small>
        </div>

        <p>Pour structurer son atelier au quotidien.</p>

        <ul>
          <li>Commandes atelier illimitées</li>
          <li>Gestion complète des clients</li>
          <li>Historique client</li>
          <li>Catalogue prestations / articles</li>
          <li>Suivi des paiements</li>
          <li>Archivage des commandes</li>
        </ul>
      </article>

      <article class="lp-plan lp-plan--featured">
        <span class="lp-plan__badge">Recommandé</span>

        <h3>Offre Essentiel</h3>

        <div class="lp-plan__price">
          <strong>24€</strong>
          <small>/ mois</small>
        </div>

        <p>L’offre recommandée pour piloter son activité.</p>

        <ul>
          <li>Paiements liés aux commandes</li>
          <li>Historique des transactions</li>
          <li>Tableau de bord chiffre d’affaires</li>
          <li>Suivi avancé des commandes</li>
          <li>Rappels clients SMS / email</li>
          <li>Relance de récupération client</li>
        </ul>
      </article>

      <article class="lp-plan">
        <h3>Offre Premium</h3>

        <div class="lp-plan__price">
          <strong>49€</strong>
          <small>/ mois</small>
        </div>

        <p>Pour professionnaliser la relation client.</p>

        <ul>
          <li>Paramétrage avancé du suivi client</li>
          <li>Choix du canal SMS ou email</li>
          <li>Modèles de messages</li>
          <li>Rappels de paiement</li>
          <li>Rapports d’activité</li>
          <li>Support prioritaire</li>
        </ul>
      </article>
    </div>
  </section>

  <%# Bas de page %>
  <section class="lp-final-cta">
    <div class="lp-final-cta__shape lp-final-cta__shape--left"></div>
    <div class="lp-final-cta__shape lp-final-cta__shape--right"></div>

    <div class="lp-final-cta__content">
      <h2>
        <% if user_signed_in? %>
          Continuez à piloter votre atelier.
        <% else %>
          Reprenez le contrôle sur votre atelier.
        <% end %>
      </h2>

      <p>
        <% if user_signed_in? %>
          Retrouvez vos commandes, vos clients, vos paiements et votre suivi client
          depuis votre espace Popwear Pro.
        <% else %>
          Commandes, clients, paiements et rappels clients réunis dans un seul
          outil pensé pour les artisans. Simple à prendre en main, sérieux dans la durée.
        <% end %>
      </p>

      <div class="lp-final-cta__actions">
        <% if user_signed_in? %>
          <%= link_to "Accéder à l'app", dashboard_path, class: "lp-btn lp-final-cta__btn-primary" %>
          <%= link_to "Se déconnecter",
                      destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "lp-btn lp-final-cta__btn-secondary" %>
        <% else %>
          <%= link_to "Essayer Popwear Pro", new_user_registration_path, class: "lp-btn lp-final-cta__btn-primary" %>
          <%= link_to "Se connecter", new_user_session_path, class: "lp-btn lp-final-cta__btn-secondary" %>
        <% end %>
      </div>
    </div>
  </section>

  <footer class="lp-footer-minimal">
    <%= image_tag "logo-popwear-pro.png", alt: "Popwear Pro", class: "lp-footer-minimal__logo" %>

    <p>
      © 2026 Popwear Pro — La plateforme de gestion des ateliers artisanaux
    </p>
  </footer>

</div>
