<% average_recent_order = @recent_orders.any? ? (@recent_orders.sum { |order| order.total_ttc.to_f } / @recent_orders.count) : 0 %>
<% recent_orders_total = @recent_orders.sum { |order| order.total_ttc.to_f } %>

<%
  status_labels = {
    "new" => "Nouvelle",
    "pending" => "En attente de retrait",
    "in_progress" => "En cours",
    "recollect" => "En attente de retrait",
    "done" => "Terminée",
    "completed" => "Terminée",
    "delivered" => "Terminée",
    "sent" => "Envoyée",
    "cancelled" => "Annulée"
  }

  status_classes = {
    "new" => "dashboard-v2__status-badge--new",
    "pending" => "dashboard-v2__status-badge--recollect",
    "in_progress" => "dashboard-v2__status-badge--in-progress",
    "recollect" => "dashboard-v2__status-badge--recollect",
    "done" => "dashboard-v2__status-badge--done",
    "completed" => "dashboard-v2__status-badge--done",
    "delivered" => "dashboard-v2__status-badge--done",
    "sent" => "dashboard-v2__status-badge--sent",
    "cancelled" => "dashboard-v2__status-badge--cancelled"
  }

  french_days = ["dimanche", "lundi", "mardi", "mercredi", "jeudi", "vendredi", "samedi"]

  french_months = [
    nil,
    "janvier",
    "février",
    "mars",
    "avril",
    "mai",
    "juin",
    "juillet",
    "août",
    "septembre",
    "octobre",
    "novembre",
    "décembre"
  ]

  today_label = "#{french_days[Date.current.wday].capitalize} #{Date.current.day} #{french_months[Date.current.month]} #{Date.current.year}"

  date_label = lambda do |date|
    date.present? ? "#{date.day} #{french_months[date.month]} #{date.year}" : "—"
  end
%>

<div class="dashboard-v2">
  <div class="dashboard-v2__topbar">
    <div>
      <h1>Tableau de bord</h1>
      <p>Vue d’ensemble de l’activité de <%= @establishment.name %>.</p>
    </div>

    <div class="dashboard-v2__actions">
      <%= link_to new_order_path, class: "dashboard-v2__btn dashboard-v2__btn--primary" do %>
        <i class="fa-solid fa-plus"></i>
        <span>Nouvelle commande</span>
      <% end %>

      <% if defined?(new_sale_path) %>
        <%= link_to new_sale_path, class: "dashboard-v2__btn dashboard-v2__btn--primary" do %>
          <i class="fa-solid fa-cash-register"></i>
          <span>Nouvelle vente</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="dashboard-v2__section-head">
    <h2>Votre journée</h2>

    <span class="dashboard-v2__date-pill">
      <i class="fa-solid fa-calendar-day"></i>
      <%= today_label %>
    </span>
  </div>

  <div class="dashboard-v2__quick-stats">
    <%= link_to orders_path, class: "dashboard-v2__quick-card dashboard-v2__quick-card--green" do %>
      <div class="dashboard-v2__quick-icon dashboard-v2__quick-icon--green">
        <i class="fa-solid fa-cash-register"></i>
      </div>

      <h3>
        <%= number_to_currency(@revenue, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
      </h3>

      <p>Chiffre encaissé</p>
    <% end %>

    <%= link_to orders_path, class: "dashboard-v2__quick-card dashboard-v2__quick-card--orange" do %>
      <div class="dashboard-v2__quick-icon dashboard-v2__quick-icon--orange">
        <i class="fa-solid fa-clipboard-list"></i>
      </div>

      <h3><%= @recent_orders.count %></h3>
      <p>Commandes récentes</p>
    <% end %>

    <%= link_to orders_path, class: "dashboard-v2__quick-card dashboard-v2__quick-card--yellow" do %>
      <div class="dashboard-v2__quick-icon dashboard-v2__quick-icon--yellow">
        <i class="fa-solid fa-clock"></i>
      </div>

      <h3><%= @urgent_orders.count %></h3>
      <p>Commandes urgentes</p>
    <% end %>

    <%= link_to orders_path, class: "dashboard-v2__quick-card dashboard-v2__quick-card--coral" do %>
      <div class="dashboard-v2__quick-icon dashboard-v2__quick-icon--coral">
        <i class="fa-solid fa-scissors"></i>
      </div>

      <h3><%= @orders_in_progress.count %></h3>
      <p>À traiter</p>
    <% end %>

    <%= link_to customers_path, class: "dashboard-v2__quick-card dashboard-v2__quick-card--peach" do %>
      <div class="dashboard-v2__quick-icon dashboard-v2__quick-icon--peach">
        <i class="fa-solid fa-address-book"></i>
      </div>

      <h3><%= @customers.count %></h3>
      <p>Clients</p>
    <% end %>
  </div>

  <section class="dashboard-v2__summary-card">
    <div class="dashboard-v2__summary-header">
      <h2>Résumé de l’activité</h2>

      <div class="dashboard-v2__summary-actions">
        <button type="button" class="dashboard-v2__filter-btn">
          Ce mois-ci
          <i class="fa-solid fa-chevron-down"></i>
        </button>

        <%= link_to orders_path, class: "dashboard-v2__small-btn" do %>
          Voir les commandes
          <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>
    </div>

    <div class="dashboard-v2__summary-grid">
      <div class="dashboard-v2__summary-item">
        <div>
          <h3>
            <%= number_to_currency(recent_orders_total, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
          </h3>
          <p>Montant des dernières commandes</p>
        </div>

        <div class="dashboard-v2__summary-icon dashboard-v2__summary-icon--cash">
          <i class="fa-solid fa-receipt"></i>
        </div>
      </div>

      <div class="dashboard-v2__summary-item">
        <div>
          <h3>
            <%= number_to_currency(average_recent_order, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
          </h3>
          <p>Panier moyen récent</p>
        </div>

        <div class="dashboard-v2__summary-icon dashboard-v2__summary-icon--cart">
          <i class="fa-solid fa-chart-line"></i>
        </div>
      </div>

      <div class="dashboard-v2__summary-item">
        <div>
          <h3><%= @orders_in_progress.count %></h3>
          <p>Commandes en cours</p>
        </div>

        <div class="dashboard-v2__summary-icon dashboard-v2__summary-icon--work">
          <i class="fa-solid fa-scissors"></i>
        </div>
      </div>

      <div class="dashboard-v2__summary-item">
        <div>
          <h3><%= @customers.count %></h3>
          <p>Clients enregistrés</p>
        </div>

        <div class="dashboard-v2__summary-icon dashboard-v2__summary-icon--clients">
          <i class="fa-solid fa-address-book"></i>
        </div>
      </div>
    </div>
  </section>

  <div class="dashboard-v2__bottom-grid">
    <section class="dashboard-v2__panel dashboard-v2__panel--large">
      <div class="dashboard-v2__panel-head">
        <div>
          <h2>Commandes en cours</h2>
          <p><%= @orders_in_progress.count %> réparation(s) & création(s) en cours</p>
        </div>

        <%= link_to orders_path, class: "dashboard-v2__link" do %>
          Gérer les commandes
          <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <% if @orders_in_progress.any? %>
        <div class="dashboard-v2__table-wrap">
          <table class="dashboard-v2__table">
            <thead>
              <tr>
                <th>Client</th>
                <th>Déposée le</th>
                <th>Montant</th>
                <th>Statut</th>
              </tr>
            </thead>

            <tbody>
              <% @orders_in_progress.first(6).each do |order| %>
                <% current_status = order.status.to_s %>

                <tr>
                  <td>
                    <strong><%= order.customer.display_name %></strong>
                  </td>

                  <td>
                    <%= date_label.call(order.created_at&.to_date) %>
                  </td>

                  <td>
                    <%= number_to_currency(order.total_ttc, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                  </td>

                  <td>
                    <span class="dashboard-v2__status-badge <%= status_classes[current_status] || "dashboard-v2__status-badge--default" %>">
                      <%= status_labels[current_status] || current_status.humanize %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="dashboard-v2__empty-state">Aucune commande en cours.</p>
      <% end %>
    </section>

    <section class="dashboard-v2__panel">
      <div class="dashboard-v2__panel-head">
        <div>
          <h2>Derniers clients</h2>
          <p>Vos clients ajoutés récemment</p>
        </div>

        <%= link_to customers_path, class: "dashboard-v2__small-btn" do %>
          Voir tout
          <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <% if @recent_customers.any? %>
        <div class="dashboard-v2__clients-list">
          <% @recent_customers.each do |customer| %>
            <div class="dashboard-v2__client-row">
              <div>
                <strong><%= customer.firstname %> <%= customer.lastname %></strong>
                <p><%= customer.phone.presence || "Téléphone non renseigné" %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="dashboard-v2__empty-state">Aucun client pour le moment.</p>
      <% end %>
    </section>
  </div>
</div>
